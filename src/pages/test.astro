---
interface AccordionItem {
  question: string;
  answer: string;
}
import { ArrowDown, ChevronDown } from '@lucide/astro';
import Layout from '../layouts/layout.astro';
import SectionHeading from '../components/section-heading.astro';

const faqItems: AccordionItem[] = [
  {
    question: 'What is the warranty period for TOT SD NEXGEN windows?',
    answer:
      'We provide a comprehensive 25-year warranty on our TOT SD NEXGEN sliding windows, covering manufacturing defects, hardware functionality, and weather sealing performance. This warranty ensures peace of mind and long-term reliability for your investment. Our commitment to quality means you can trust the durability and performance of our windows for decades to come.',
  },
  {
    question: 'Are these windows suitable for high-rise buildings?',
    answer:
      'Yes, TOT SD NEXGEN windows are engineered for high wind loads and structural safety, making them suitable for high-rise buildings.',
  },
  {
    question: 'What glass options are available?',
    answer:
      'We offer a variety of glass types, including clear, tinted, frosted, and laminated options depending on your privacy and insulation needs.',
  },
  {
    question: 'How long does installation take?',
    answer:
      'Installation typically takes 2–5 hours per unit depending on site readiness and number of windows.',
  },
  {
    question: 'Can I customize the window dimensions?',
    answer:
      'Yes, we support fully customized dimensions to suit your architectural requirements.',
  },
  {
    question: 'What maintenance is required?',
    answer:
      'Routine cleaning and occasional lubrication of tracks is sufficient. No intensive maintenance needed.',
  },
  {
    question: 'Are the windows energy efficient?',
    answer:
      'Yes, with multiple glass options and precision sealing, they significantly reduce energy loss.',
  },
  {
    question: 'What colors and finishes are available?',
    answer:
      'A range of powder-coated and anodized finishes are available in various neutral and custom colors.',
  },
];
---

<Layout title="Test Page" htmlClassName="no-js">
  <h1 class="text-3xl font-bold">Test Page</h1>
  <p>This is a test page to verify the layout and components.</p>
  <div class="max-w-6xl py-8 mx-auto px-4 space-y-4">
    <div class="text-center">
      <SectionHeading
        title="Frequently Asked Questions"
        description="Yeah Yeah Yeah Young Boy, I'm the GOAT"
      />
    </div>
    <div class="flex flex-col gap-2 md:gap-4 rounded-2xl bg-gray-50 p-2 md:p-4">
      {
        faqItems.map((item) => (
          <div class="overflow-hidden rounded-2xl border border-neutral-200 text-neutral-700 bg-white">
            <button class="peer group/trigger flex w-full justify-between items-center px-4 py-2">
              <h3 class="text-neutral-600 font-medium md:text-lg text-left">
                {item.question}
              </h3>

              <ChevronDown class="size-8 shrink-0 group-focus/trigger:rotate-180 transition-smooth md:size-10 p-1 border border-neutral-200 rounded-full stroke-1 stroke-neutral-600" />
            </button>

            <p class="max-h-0 translate-y-4 transform px-4 text-neutral-600 opacity-0 transition-all duration-300 ease-out peer-focus:max-h-[200px] peer-focus:translate-y-0 peer-focus:pb-4 peer-focus:opacity-100">
              {item.answer}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="">
    <div class="stat-card meteor-card p-4">
      <div class="meteor-container">
        <div class="meteor"></div>
        <div class="meteor meteor-2"></div>
        <div class="meteor meteor-3"></div>
      </div>
      <div class="content">
        <div class="icon">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 17L9 11L13 15L21 7"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M14 7H21V14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="number">100+</div>
        <div class="label">Projects Completed</div>
      </div>
    </div>

    <style>
      .meteor-card {
        position: relative;
        width: 280px;
        height: 200px;
        background: linear-gradient(135deg, #0f0f23, #1a1a3e);
        border-radius: 24px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        transition: transform 0.3s ease;
      }

      .meteor-card:hover {
        transform: translateY(-5px);
      }

      .meteor-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      .meteor {
        position: absolute;
        width: 2px;
        height: 2px;
        background: linear-gradient(45deg, #60a5fa, #3b82f6);
        border-radius: 50%;
        box-shadow:
          0 0 10px #60a5fa,
          0 0 20px #3b82f6,
          0 0 30px #1d4ed8;
        animation: meteorFall 3s linear infinite;
      }

      .meteor::before {
        content: '';
        position: absolute;
        top: 0;
        right: 2px;
        width: 40px;
        height: 1px;
        background: linear-gradient(90deg, transparent, #60a5fa, transparent);
        transform: rotate(-45deg);
        transform-origin: left center;
      }

      .meteor-2 {
        animation-delay: -1s;
        animation-duration: 2.5s;
      }

      .meteor-3 {
        animation-delay: -2s;
        animation-duration: 3.5s;
      }

      @keyframes meteorFall {
        0% {
          top: -10px;
          left: 100%;
          opacity: 1;
        }
        70% {
          opacity: 1;
        }
        100% {
          top: 100%;
          left: -10px;
          opacity: 0;
        }
      }

      .content {
        position: relative;
        z-index: 1;
      }

      .icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #60a5fa, #3b82f6);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        color: white;
        box-shadow: 0 8px 32px rgba(96, 165, 250, 0.3);
      }

      .icon svg {
        width: 28px;
        height: 28px;
      }

      .number {
        font-size: 48px;
        font-weight: 800;
        color: #f1f5f9;
        margin-bottom: 8px;
      }

      .label {
        font-size: 16px;
        color: #94a3b8;
        font-weight: 500;
      }
    </style>
  </div>
</Layout>

<script>
  import { initEmblas } from '../scripts/embla';
  import { initRevealObserver } from '../scripts/reveal';
  import { initTabManager } from '../scripts/tab';
  import { initExpandingCards } from '../scripts/expanding-cards';

  document.addEventListener('DOMContentLoaded', () => {
    initTabManager();
    initEmblas();

    initExpandingCards();
    initRevealObserver();
  });
</script>
