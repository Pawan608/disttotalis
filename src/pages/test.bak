---
import Layout from '../layouts/layout.astro';
import { X, User } from '@lucide/astro';
---

<Layout title="Test Page" htmlClassName="no-js">
  <button class="contact-form-trigger p-2 border border-neutral-200 shadow">
    Show Form
  </button>

  <div
    class="fixed flex inset-0 z-50 items-center w-full justify-center bg-black/70 backdrop-blur-sm transition-all duration-300 p-4 md:p-6 overflow-hidden"
    id="contact-form-modal"
  >
    <div
      class="relative max-w-3xl w-full bg-white rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto"
    >
      <div
        class="sticky top-0 bg-white/50 backdrop-blur-sm rounded-t-2xl border-b border-neutral-100 sm:p-6 p-4 pb-2 sm:pb-4"
      >
        <button
          class="close-contact-form-trigger absolute top-4 right-4 stroke-neutral-400 hover:stroke-neutral-600 focus:outline-none transition-colors cursor-pointer"
        >
          <X class="sm:size-6 size-5" />
        </button>

        <h2 class="sm:text-2xl text-xl font-semibold text-neutral-800">
          Let's Know You First
        </h2>
      </div>

      <div class="p-4 sm:p-8 sm:pt-4 pt-2" id="form-container">
        <form id="contact-form" class="space-y-4">
          <div class="space-y-2">
            <label for="fullName" class="flex items-center gap-2 text-sm font-medium text-gray-700">
              <User class="size-3" />
              <span>Full Name</span>
            </label>
            <input
              id="fullName"
              name="fullName"
              type="text"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="John Doe"
              required
            />
          </div>

          <div class="flex justify-end">
            <button
              type="submit"
              class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
            >
              Submit Application
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const handleFormSubmit = (event) => {
      event.preventDefault();

      const form = event.target;
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      console.log('Form Data:', data);
      console.log('FormData entries:', [...formData.entries()]);
      
      // Test if we can get the value directly
      const fullNameValue = form.fullName.value;
      console.log('Direct form access:', fullNameValue);
    };

    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form');
      if (form) {
        form.addEventListener('submit', handleFormSubmit);
        console.log('Form event listener attached');
      } else {
        console.log('Form not found');
      }
    });
  </script>
</Layout>