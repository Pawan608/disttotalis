---
import Layout from '../layouts/layout.astro';

import Hero from '../sections/hero.astro';
import Projects from '../sections/projects.astro';
import FeaturesSection from '../sections/features.astro';
import TableComparisonSection from '../sections/table-comparison.astro';
import CtaEnd from '../sections/cta-end.astro';
import CredibilitySection from '../sections/credibility.astro';
---

<Layout title="Totalis - By Hindalco" htmlClassName="no-js">
  <Hero />
  <CredibilitySection />
  <TableComparisonSection />
  <FeaturesSection />
  <Projects />
  <CtaEnd />

  <script>
    import { initCardGlowEffect } from '../scripts/glow';
    import { initRevealObserver } from '../scripts/reveal';

    // All DOMContentLoaded centralized logic
    document.addEventListener('DOMContentLoaded', () => {
      const hindalcoLogo = document.getElementById('hindalco-logo');
      const backedCard = document.getElementById('backed-card');
      const isWideScreen = window.innerWidth > 768;
      const isHeightLarge = window.innerHeight > 650;
      const hindalcoLogoAnimDelay = isHeightLarge ? 700 : 100;
      const backedCardAnimDelay = isHeightLarge && isWideScreen ? 750 : 100;

      hindalcoLogo?.setAttribute('data-delay', `${hindalcoLogoAnimDelay}`);
      backedCard?.setAttribute('data-delay', `${backedCardAnimDelay}`);

      initRevealObserver();
      initCardGlowEffect();
    });
  </script>
</Layout>
