---
import { Image } from 'astro:assets';
import Hero from '../components/hero.astro';
import Layout from '../layouts/layout.astro';
import hindalcoLogo from '../assets/hindalco.jpg';

import {
  Sparkle,
  Settings,
  Wind,
  Droplet,
  AirVent,
  CheckCircle,
  XCircle,
} from '@lucide/astro';
import ProjectSlider from '../components/project-slider.astro';
import SectionHeading from '../components/section-heading.astro';

// General performance stats
const capsules = [
  { title: 'No. 1', description: 'Aluminium Producer Globally' },
  { title: '52', description: 'Manufacturing Facilities Globally' },
  { title: '85', description: 'Extrusion Plants in INDIA' },
  { title: '12', description: 'Global R&D Centres' },
];

// Climatic performance features
const climaticCapsules = [
  {
    title: 'Engineered Strength',
    description:
      'Precision-engineered for structural integrity and long-term durability—even in harsh climates.',
    icon: Settings,
  },
  {
    title: 'Wind Resistance',
    description:
      'Tested for high wind loads to ensure safety in high-rises and coastal zones.',
    icon: Wind,
  },
  {
    title: 'Water Tightness',
    description:
      'Sealed to resist rainwater penetration—protects your interiors during monsoons.',
    icon: Droplet,
  },
  {
    title: 'Air Infiltration',
    description:
      'Engineered to prevent air leakage and enhance energy efficiency indoors.',
    icon: AirVent,
  },
];

// Comparison table data
const comparisonData = [
  {
    benefit: 'High Structural Strength',
    aluminium: { status: 'positive', text: 'Yes' },
    upvc: { status: 'negative', text: 'Limited' },
  },
  {
    benefit: 'Slim, Sleek Aesthetics',
    aluminium: { status: 'positive', text: 'Ultra-slim frames' },
    upvc: { status: 'negative', text: 'Bulky' },
  },
  {
    benefit: 'Long-term Durability',
    aluminium: { status: 'positive', text: 'Rust & Warp proof' },
    upvc: { status: 'negative', text: 'Prone to Discolouration/Cracks' },
  },
  {
    benefit: 'Fire & Heat Resistance',
    aluminium: { status: 'positive', text: 'Non-combustible' },
    upvc: { status: 'negative', text: 'Melts easily' },
  },
  {
    benefit: 'Eco-Friendly & Recyclable',
    aluminium: { status: 'positive', text: '100% Recyclable' },
    upvc: { status: 'negative', text: 'Plastic waste' },
  },
  {
    benefit: 'Customisation Flexibility',
    aluminium: { status: 'positive', text: 'High' },
    upvc: { status: 'negative', text: 'Limited' },
  },
  {
    benefit: 'Thermal & Acoustic Insulation',
    aluminium: { status: 'positive', text: 'Superior Technologies' },
    upvc: { status: 'negative', text: 'Basic only' },
  },
  {
    benefit: 'Premium Look & Feel',
    aluminium: { status: 'positive', text: 'Architectural Grade' },
    upvc: { status: 'negative', text: 'Plastic finish' },
  },
];
---

<Layout title="Totalis - By Hindalco" htmlClassName="no-js">
  <Hero />

  <section id="content" class="px-4 max-w-6xl mx-auto">
    <!-- Hero Section -->
    <div class="my-4 grid md:grid-cols-2 py-4 items-center">
      <Image
        src={hindalcoLogo}
        alt="Hindalco"
        layout="constrained"
        class="px-4 py-8 md:px-16 reveal"
        data-delay="100"
        loading="eager"
        decoding="async"
      />

      <div
        class="relative bg-primary flex flex-col justify-center px-12 py-8 min-h-64 text-white rounded-xl reveal"
        data-delay="100"
      >
        <Sparkle class="absolute top-6 right-4 stroke-0 fill-amber-300" />
        <h3 class="text-3xl py-2 font-semibold">
          Backed by a Legacy of Material Excellence
        </h3>
        <p class="font-light text-md py-2 tracking-wide">
          Totalis is crafted by Hindalco, a global aluminium leader and part of
          the Aditya Birla Group — a name trusted for generations.
        </p>
      </div>
    </div>

    <!-- Global Stats -->
    <div
      class="my-4 grid grid-cols-1 sm:grid-cols-2 lg:bg-modal-blue lg:rounded-2xl lg:grid-cols-4 lg:gap-1.5 gap-2 sm:gap-2.5 text-center"
    >
      {
        capsules.map((capsule, i) => (
          <div class="p-6 rounded-xl not-lg:bg-modal-blue not-lg:reveal flex flex-col gap-2">
            <h2
              class="text-4xl font-bold text-modal-blue-dark reveal"
              data-delay={i * 50}
            >
              {capsule.title}
            </h2>
            <p class="text-gray-700 text-sm">{capsule.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Climatic Capsule Section -->
    <div class="text-center py-8 lg:py-16">
      <SectionHeading
        title="Tested and Certified for Indian Climatic Conditions"
        description="Totalis system aluminium windows are built for performance. Certified for peace of mind."
      />

      <div
        class="mt-6 lg:mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 text-left"
      >
        {
          climaticCapsules.map((item, i) => (
            <div data-delay={(i + 1) * 200} class="reveal relative">
              <div class="glow-card flex flex-col relative p-6 rounded-2xl border border-primary/20 overflow-hidden h-72 bg-white">
                <div class="mb-4 grow">
                  <item.icon
                    size={64}
                    stroke-width={1}
                    class="stroke-primary"
                  />
                </div>
                <h4 class="font-semibold text-lg mb-1">{item.title}</h4>
                <p class="text-gray-700 text-sm">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Comparison Table Section -->
  <section id="checklist-table" class="px-4 max-w-6xl mx-auto">
    <div class="text-center py-8 lg:py-16">
      <SectionHeading
        title="Engineered to Outperform uPVC"
        description="Why system aluminium is the smarter, stronger choice."
      />

      <!-- Comparison Table -->
      <div class="mt-8 lg:mt-12 overflow-x-auto">
        <div
          class="min-w-full bg-white rounded-2xl shadow-lg overflow-hidden reveal"
          data-delay="100"
        >
          <!-- Table Header -->
          <div
            class="grid grid-cols-3 bg-gradient-to-r from-blue-900 to-blue-800 text-white"
          >
            <div class="p-4 lg:p-6 text-left font-semibold text-lg">
              Benefit
            </div>
            <div
              class="p-4 lg:p-6 text-center font-semibold text-lg border-l border-blue-700"
            >
              Aluminium
            </div>
            <div
              class="p-4 lg:p-6 text-center font-semibold text-lg border-l border-blue-700"
            >
              uPVC
            </div>
          </div>

          <!-- Table Body -->
          {
            comparisonData.map((row, i) => (
              <div
                class={`grid grid-cols-3 ${i % 2 === 0 ? 'bg-green-50' : 'bg-white'} reveal`}
                data-delay={i * 100}
              >
                <div class="p-4 lg:p-6 text-left font-medium text-gray-800 border-b border-gray-200">
                  {row.benefit}
                </div>
                <div class="p-4 lg:p-6 text-center border-b border-gray-200 border-l">
                  <div class="flex items-center gap-2">
                    <CheckCircle class="w-5 h-5 text-green-500" />
                    <span class="text-green-700 font-medium">
                      {row.aluminium.text}
                    </span>
                  </div>
                </div>
                <div class="p-4 lg:p-6 text-center border-b border-gray-200 border-l">
                  <div class="flex items-center gap-2">
                    <XCircle class="w-5 h-5 text-red-600" />
                    <span class="text-red-700 font-medium">
                      {row.upvc.text}
                    </span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects">
    <ProjectSlider />
  </section>
</Layout>

<script>
  import { initCardGlowEffect } from '../scripts/glow';
  import { initRevealObserver } from '../scripts/reveal';

  document.addEventListener('DOMContentLoaded', () => {
    initRevealObserver();
    initCardGlowEffect();
  });
</script>
