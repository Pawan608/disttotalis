---
import { CheckCircle, ChevronRight, Home, Star } from '@lucide/astro';
import Layout from '../../layouts/layout.astro';
import { products } from '../../lib/products';
import { Image } from 'astro:assets';
import Button from '../../components/button.astro';
import CtaEnd from '../../sections/cta-end.astro';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout title={product.name}>
  <section class="bg-white">
    <div
      class="h-12 border-b border-gray-200 sticky top-16 bg-white z-10 flex items-center justify-center"
    >
      <div
        class="w-full text-gray-500 flex items-center px-4 max-w-6xl text-sm font-light"
      >
        <span class="font-medium flex items-center gap-1 text-gray-700">
          <!-- <Home class="stroke-1.5 size-4" /> -->
          <span>Home</span>
        </span>
        <ChevronRight class="size-4 mx-0.5" />
        <span class="">Product</span>
        <ChevronRight class="size-4 mx-0.5" />
        <span>Sliding Windows</span>
        <ChevronRight class="size-4 mx-0.5" />
        <span class="text-secondary font-normal">{product.name}</span>
      </div>
    </div>
    <div class="max-w-6xl mt-8 mx-auto px-4 grid md:grid-cols-2 gap-16">
      <!-- Main Image -->
      <div class="space-y-8">
        <div
          class="aspect-square w-full max-w-lg mx-auto rounded-2xl overflow-hidden border border-gray-200 shadow-md relative"
        >
          <Image
            src={product.mainImage}
            alt={product.name}
            class="w-full h-full object-cover"
          />
          <div
            class="absolute top-4 left-4 bg-primary text-white text-sm px-2 py-0.5 rounded-md"
          >
            BIS Certified
          </div>
        </div>
        <div class="flex gap-4 justify-center">
          {
            product.thumbnails.map((img, i) => (
              <div class="aspect-square w-16 rounded-lg overflow-hidden border border-gray-300">
                <Image
                  src={img}
                  alt={`Thumb ${i + 1}`}
                  class="w-full h-full object-cover"
                />
              </div>
            ))
          }
        </div>
      </div>

      <!-- Product Info -->
      <div class="flex flex-col justify-between space-y-8">
        <div class="space-y-4">
          <div class="space-y-4">
            <p
              class="uppercase text-xs text-secondary border border-secondary px-2 shadow-xs shadow-secondary/35 rounded max-w-fit"
            >
              Sliding Window
            </p>
            <h1 class="text-4xl font-bold text-gray-900">{product.name}</h1>
            <p class="text-base text-gray-600">{product.description}</p>
          </div>

          <div
            class="p-4 flex gap-2 items-center border border-green-200 bg-green-50 rounded-xl text-green-700"
          >
            <Star class="w-6 h-6 mt-1 stroke-transparent fill-green-600" />
            <div>
              <h5 class="font-semibold">Premium Quality Assured</h5>
              <p class="text-sm">
                Tested & Certified for Indian Climate Conditions
              </p>
            </div>
          </div>
          <div class="space-y-4">
            <h2 class="text-2xl font-semibold">Key Feature</h2>
            <div class="grid grid-cols-1 gap-2">
              {
                product.features.map((f) => (
                  <div class="flex p-4 items-start gap-4 rounded-xl shadow-xs border border-gray-200">
                    <div class="bg-secondary/10 border border-secondary/15 rounded-lg p-2 self-center">
                      <f.icon class="w-6 h-6 stroke-secondary" />
                    </div>
                    <div>
                      <p class="text-base font-semibold text-gray-800">
                        {f.title}
                      </p>
                      <p class="text-sm text-gray-500">{f.text}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- <div class="space-y-2"> -->
        <div class="flex gap-4">
          <Button
            variant="secondary-blue"
            class="transition-smooth"
            reveal={'true'}>Request Quote</Button
          >
          <Button
            variant="outline"
            class="transition-smooth transition-all"
            reveal="true"
            animationDelay="100">Download Catalog</Button
          >
          <!-- </div> -->
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div
      class="max-w-6xl mx-auto px-4 mt-16 mb-8 grid grid-cols-2 md:grid-cols-4 gap-4 text-center"
    >
      {
        product.stats.map((s) => (
          <div class="border glow-card overflow-hidden border-gray-200 shadow py-8 rounded-2xl flex flex-col items-center">
            <div class="w-12 aspect-square flex items-center mb-2 justify-center rounded-xl bg-secondary border border-secondary-light">
              <s.icon class="size-8 stroke-[1.7] stroke-white" />
            </div>
            <p class="text-2xl font-bold text-secondary">{s.value}</p>
            <p class="text-sm text-gray-500">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaEnd />

  <script>
    import { initCardGlowEffect } from '../../scripts/glow';
    import { initRevealObserver } from '../../scripts/reveal';

    // All DOMContentLoaded centralized logic
    document.addEventListener('DOMContentLoaded', () => {
      initRevealObserver();
      initCardGlowEffect();
    });
  </script>
</Layout>
