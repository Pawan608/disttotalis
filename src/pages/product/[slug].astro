---
import { ChevronRight } from '@lucide/astro';
import Layout from '../../layouts/layout.astro';
import { products } from '../../lib/products';
import CtaEnd from '../../sections/cta-end.astro';
import ProductCollection from '../../sections/product-collection.astro';
import HandleOptions from '../../sections/handle-options.astro';
import Faq from '../../sections/faq.astro';
import ProductIntroduction from '../../sections/product-introduction.astro';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout
  title={product.name}
  description={`Totalis By Hindalco - ${product.name} - ${product.description}`}
>
  <!-- Breadcrumb -->
  <div
    class="h-12 border-gray-200 sticky top-16 bg-white z-10 flex items-center justify-center"
  >
    <div
      class="w-full text-gray-500 flex items-center px-4 max-w-6xl text-sm font-light"
    >
      <span class="font-medium flex items-center gap-1 text-gray-700">
        <span>Home</span>
      </span>
      <ChevronRight class="size-4 mx-0.5" />
      <span>Product</span>
      <ChevronRight class="size-4 mx-0.5" />
      <span>Sliding Windows</span>
      <ChevronRight class="size-4 mx-0.5" />
      <span class="text-secondary font-normal">{product.name}</span>
    </div>
  </div>

  <ProductIntroduction product={product} />

  <HandleOptions />
  <Faq />
  <ProductCollection />

  <CtaEnd />

  <script>
    import { initExpandingCards } from '../../scripts/expanding-cards';
    import { initCardGlowEffect } from '../../scripts/glow';
    import { initRevealObserver } from '../../scripts/reveal';
    import { initTabManager } from '../../scripts/tab';

    // Image gallery functionality
    function initImageGallery() {
      const mainImage = document.getElementById(
        'main-product-image'
      ) as HTMLImageElement;
      const thumbnailButtons = document.querySelectorAll(
        '.thumbnail-btn'
      ) as NodeListOf<HTMLButtonElement>;

      if (!mainImage || !thumbnailButtons.length) return;

      thumbnailButtons.forEach((button, index) => {
        button.addEventListener('click', () => {
          const imageSrc = button.dataset.imageSrc;
          const imageAlt = button.dataset.imageAlt;

          if (imageSrc && imageAlt) {
            // Update main image with fade effect
            mainImage.style.opacity = '0';

            setTimeout(() => {
              mainImage.src = imageSrc;
              mainImage.alt = imageAlt;
              mainImage.style.opacity = '1';
            }, 150);

            // Update thumbnail borders (active state)
            thumbnailButtons.forEach((btn) => {
              btn.classList.remove('border-secondary');
              btn.classList.add('border-gray-300');
            });

            button.classList.remove('border-gray-300');
            button.classList.add('border-secondary');
          }
        });
      });
    }

    // Initialize all functionality when DOM is loaded
    document.addEventListener('DOMContentLoaded', () => {
      initRevealObserver();
      initCardGlowEffect();
      initExpandingCards();
      initImageGallery();
      initTabManager();
    });
  </script>
</Layout>
