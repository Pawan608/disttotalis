---
import { CheckCircle, ChevronRight, Home, Star } from '@lucide/astro';
import Layout from '../../layouts/layout.astro';
import { products } from '../../lib/products';
import { Image } from 'astro:assets';
import Button from '../../components/button.astro';
import CtaEnd from '../../sections/cta-end.astro';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout title={product.name}>
  <!-- Breadcrumb -->
  <div
    class="h-12 border-b border-gray-200 sticky top-16 bg-white z-10 flex items-center justify-center"
  >
    <div
      class="w-full text-gray-500 flex items-center px-4 max-w-6xl text-sm font-light"
    >
      <span class="font-medium flex items-center gap-1 text-gray-700">
        <span>Home</span>
      </span>
      <ChevronRight class="size-4 mx-0.5" />
      <span>Product</span>
      <ChevronRight class="size-4 mx-0.5" />
      <span>Sliding Windows</span>
      <ChevronRight class="size-4 mx-0.5" />
      <span class="text-secondary font-normal">{product.name}</span>
    </div>
  </div>
  <section class="bg-white">
    <div class="max-w-6xl mt-8 mx-auto px-4 grid md:grid-cols-2 gap-16">
      <!-- Image Gallery -->
      <div class="space-y-8">
        <!-- Main Image Display -->
        <div
          class="aspect-square w-full max-w-lg mx-auto rounded-2xl overflow-hidden border border-gray-200 shadow-md relative"
        >
          <Image
            id="main-product-image"
            loading={'eager'}
            format="webp"
            src={product.mainImage}
            alt={product.name}
            class="w-full h-full object-cover transition-opacity duration-300"
          />
          <div
            class="absolute top-4 left-4 bg-primary text-white text-sm px-2 py-0.5 rounded-md"
          >
            BIS Certified
          </div>
        </div>

        <!-- Thumbnail Gallery -->
        <div class="flex gap-4 justify-center">
          <!-- Main image thumbnail -->
          <button
            class="thumbnail-btn aspect-square w-16 rounded-lg overflow-hidden transition-all duration-200 hover:border-secondary/80"
            data-image-src={product.mainImage.src}
            data-image-alt={product.name}
          >
            <Image
              src={product.mainImage}
              alt={`${product.name} main`}
              class="w-full h-full object-cover"
            />
          </button>

          <!-- Additional thumbnails -->
          {
            product.thumbnails.map((img, i) => (
              <button
                class="thumbnail-btn aspect-square w-16 rounded-lg overflow-hidden transition-all duration-200 hover:brightness-50 active:outline-gray-300 outline-2 outline-offset-2 outline-transparent"
                data-image-src={img.src}
                data-image-alt={`${product.name} view ${i + 1}`}
              >
                <Image
                  src={img}
                  loading={'lazy'}
                  alt={`${product.name} thumbnail ${i + 1}`}
                  class="w-full h-full object-cover"
                />
              </button>
            ))
          }
        </div>
      </div>

      <!-- Product Information -->
      <div class="flex flex-col justify-between space-y-8">
        <div class="space-y-4">
          <!-- Product Header -->
          <div class="space-y-4">
            <p
              class="uppercase text-xs text-secondary border border-secondary px-2 shadow-xs shadow-secondary/35 rounded max-w-fit"
            >
              Sliding Window
            </p>
            <h1 class="text-4xl font-bold text-gray-900">{product.name}</h1>
            <p class="text-base text-gray-600">{product.description}</p>
          </div>

          <!-- Quality Badge -->
          <div
            class="p-4 flex gap-2 items-center border border-green-200 bg-green-50 rounded-xl text-green-700"
          >
            <Star class="w-6 h-6 mt-1 stroke-transparent fill-green-600" />
            <div>
              <h5 class="font-semibold">Premium Quality Assured</h5>
              <p class="text-sm">
                Tested & Certified for Indian Climate Conditions
              </p>
            </div>
          </div>

          <!-- Key Features -->
          <div class="space-y-4">
            <h2 class="text-2xl font-semibold">Key Features</h2>
            <div class="grid grid-cols-1 gap-2">
              {
                product.features.map((feature) => (
                  <div class="flex p-4 items-start gap-4 rounded-xl shadow-xs border border-gray-200">
                    <div class="bg-secondary/10 border border-secondary/15 rounded-lg p-2 self-center">
                      <feature.icon class="w-6 h-6 stroke-secondary" />
                    </div>
                    <div>
                      <p class="text-base font-semibold text-gray-800">
                        {feature.title}
                      </p>
                      <p class="text-sm text-gray-500">{feature.text}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-4">
          <Button variant="secondary-blue" classList="transition-smooth grow">
            Request Quote
          </Button>
          <Button variant="outline" classList="transition-smooth grow">
            Download Catalog
          </Button>
        </div>
      </div>
    </div>

    <!-- Statistics -->
    <div
      class="max-w-6xl mx-auto px-4 mt-16 mb-8 grid grid-cols-2 md:grid-cols-4 gap-4 text-center"
    >
      {
        product.stats.map((stat) => (
          <div class="border glow-card z-5 overflow-hidden border-gray-200 shadow py-8 rounded-2xl flex flex-col items-center">
            <div class="w-12 aspect-square flex items-center mb-2 justify-center rounded-xl bg-secondary border border-secondary-light">
              <stat.icon class="size-8 stroke-[1.7] stroke-white" />
            </div>
            <p class="text-2xl font-bold text-secondary">{stat.value}</p>
            <p class="text-sm text-gray-500">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CtaEnd />

  <script>
    import { initCardGlowEffect } from '../../scripts/glow';
    import { initRevealObserver } from '../../scripts/reveal';

    // Image gallery functionality
    function initImageGallery() {
      const mainImage = document.getElementById(
        'main-product-image'
      ) as HTMLImageElement;
      const thumbnailButtons = document.querySelectorAll(
        '.thumbnail-btn'
      ) as NodeListOf<HTMLButtonElement>;

      if (!mainImage || !thumbnailButtons.length) return;

      thumbnailButtons.forEach((button, index) => {
        button.addEventListener('click', () => {
          const imageSrc = button.dataset.imageSrc;
          const imageAlt = button.dataset.imageAlt;

          if (imageSrc && imageAlt) {
            // Update main image with fade effect
            mainImage.style.opacity = '0';

            setTimeout(() => {
              mainImage.src = imageSrc;
              mainImage.alt = imageAlt;
              mainImage.style.opacity = '1';
            }, 150);

            // Update thumbnail borders (active state)
            thumbnailButtons.forEach((btn) => {
              btn.classList.remove('border-secondary');
              btn.classList.add('border-gray-300');
            });

            button.classList.remove('border-gray-300');
            button.classList.add('border-secondary');
          }
        });
      });
    }

    // Initialize all functionality when DOM is loaded
    document.addEventListener('DOMContentLoaded', () => {
      initRevealObserver();
      initCardGlowEffect();
      initImageGallery();
    });
  </script>
</Layout>
