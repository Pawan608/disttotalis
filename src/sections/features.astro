---
import {
  Droplet,
  Layers,
  RotateCcw,
  Zap,
  VolumeX,
  Palette,
  Lock,
  Recycle,
  Sparkles,
  ShieldBan,
  InspectionPanel,
  AudioWaveform,
  Vault,
  LockKeyhole,
  Cog,
  Sprout,
} from '@lucide/astro';
import SectionHeading from '../components/section-heading.astro';

// Features that set Totalis apart
const totalisFeatures = [
  {
    title: 'High-Quality Aluminium',
    description: 'Long lasting durability from Hindalco',
    icon: Layers,
  },
  {
    title: 'Rollers & Locks',
    description: 'Superior quality rollers and hassle-free operations.',
    icon: Cog,
  },
  {
    title: 'Leak-Proof Sealing',
    description: 'Keeps interiors dry even in heavy monsoons.',
    icon: ShieldBan,
  },
  {
    title: 'Laminated and DGU Glass',
    description: 'Helps maintain room temperature efficiently.',
    icon: Vault,
  },
  {
    title: 'Acoustic Control',
    description: 'Blocks outdoor noise for peaceful indoors.',
    icon: AudioWaveform,
  },
  {
    title: 'Custom Finishes',
    description: 'Choose from a range of premium colours.',
    icon: Sparkles,
  },
  {
    title: 'Superior Quality Locks',
    description: 'Enhanced safety with secure locking system',
    icon: LockKeyhole,
  },
  {
    title: 'Sustainable materials',
    description: '100% recyclable, made with green metal.',
    icon: Sprout,
  },
];
---

<!-- Features That Set Totalis Apart Section -->
<section id="totalis-features" class="px-4 max-w-6xl mx-auto">
  <div class="text-center py-8 lg:py-16">
    <SectionHeading
      title="Features That Set Totalis Apart"
      description="Every detail engineered for performance, durability, and design."
    />

    <div
      class="mt-8 lg:mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
    >
      {
        totalisFeatures.map((feature, i) => (
          // <div class="reveal" data-delay={i * 50}>
          <article class="glow-card bg-white rounded-2xl border border-gray-200 p-6 text-center hover:shadow-lg">
            <div class="mb-4 flex justify-center">
              <div class="w-16 h-16 bg-primary/5 rounded-full flex items-center justify-center">
                <feature.icon
                  size={40}
                  size={32}
                  class="stroke-primary"
                  stroke-width={1.5}
                />
              </div>
            </div>
            <h3 class="font-semibold text-lg mb-2 text-secondary">
              {feature.title}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              {feature.description}
            </p>
          </article>
          // </div>
        ))
      }
    </div>
  </div>
</section>
