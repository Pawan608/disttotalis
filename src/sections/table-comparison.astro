---
import { CheckCircle, XCircle } from '@lucide/astro';
import SectionHeading from '../components/section-heading.astro';

const comparisonData = [
  {
    benefit: 'High Structural Strength',
    aluminium: 'Yes',
    upvc: 'Limited',
  },
  {
    benefit: 'Slim, Sleek Aesthetics',
    aluminium: 'Ultra-slim frames',
    upvc: 'Bulky',
  },
  {
    benefit: 'Long-term Durability',
    aluminium: 'Rust & Warp proof',
    upvc: 'Prone to Discolouration & Cracks',
  },
  {
    benefit: 'Fire & Heat Resistance',
    aluminium: 'Non-combustible',
    upvc: 'Melts easily',
  },
  {
    benefit: 'Eco-Friendly & Recyclable',
    aluminium: '100% Recyclable',
    upvc: 'Plastic waste',
  },
  {
    benefit: 'Customisation Flexibility',
    aluminium: 'High',
    upvc: 'Limited',
  },
  {
    benefit: 'Thermal & Acoustic Insulation',
    aluminium: 'Superior Technologies',
    upvc: 'Basic only',
  },
  {
    benefit: 'Premium Look & Feel',
    aluminium: 'Architectural Grade',
    upvc: 'Plastic finish',
  },
];
---

<section id="checklist-table" class="px-4 max-w-6xl mx-auto">
  <div class="text-center py-8 lg:py-16">
    <SectionHeading
      title="Engineered to Outperform uPVC"
      description="Why system aluminium is the smarter, stronger choice."
    />

    <div class="overflow-hidden mt-8 lg:mt-12 rounded-2xl shadow-lg">
      <div class="overflow-x-auto">
        <table class="min-w-full bg-white">
          <thead>
            <tr class="bg-secondary text-white">
              <th
                class="p-4 lg:p-6 text-left font-semibold text-lg min-w-[12rem]"
              >
                Benefit
              </th>
              <th
                class="p-4 lg:p-6 text-center font-semibold text-lg border-l border-secondary min-w-[12rem]"
              >
                Aluminium
              </th>
              <th
                class="p-4 lg:p-6 text-center font-semibold text-lg border-l border-secondary min-w-[12rem]"
              >
                uPVC
              </th>
            </tr>
          </thead>
          <tbody>
            {
              comparisonData.map((row) => (
                <tr>
                  <td class="p-4 lg:p-6 text-left font-medium text-gray-800 border-b border-gray-200 text-sm md:text-base bg-[rgb(223,255,208)]">
                    {row.benefit}
                  </td>
                  <td class="p-4 lg:p-6 border-b border-gray-200 border-l bg-[rgb(240,255,230)]">
                    <div class="flex gap-2">
                      <CheckCircle class="size-4 md:size-5 mt-0.5 text-green-500 shrink-0" />
                      <span class="text-green-700 text-left font-medium text-sm md:text-base">
                        {row.aluminium}
                      </span>
                    </div>
                  </td>
                  <td class="p-4 lg:p-6 border-b border-gray-200 border-l">
                    <div class="flex gap-2">
                      <XCircle class="size-4 md:size-5 mt-0.5 text-red-600 shrink-0" />
                      <span class="text-red-700 text-left font-medium text-sm md:text-base">
                        {row.upvc}
                      </span>
                    </div>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
