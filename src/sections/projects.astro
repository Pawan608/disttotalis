---
import { CircleArrowLeft, CircleArrowRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import demoImage from '../assets/building.jpeg';
import demoBuilding from '../assets/hotel-building.jpg';
import demoBuilding1 from '../assets/building-placeholder.jpg';
import Marquee from '../components/marquee.astro';

const properties = [
  { id: 1, name: 'Supreme, Pune', area: '88544 Sqft.', image: demoBuilding1 },
  {
    id: 2,
    name: 'Shalimar Mannat, Lucknow',
    area: '88544 Sqft.',
    image: demoBuilding,
  },
  { id: 3, name: 'Eldeco Luxa', area: '30000 Sqft.', image: demoImage },
  {
    id: 4,
    name: 'Natura by One Oak, Lucknow',
    area: '75114 Sqft.',
    image: demoImage,
  },
  {
    id: 5,
    name: 'Supreme Elite, Mumbai',
    area: '95000 Sqft.',
    image: demoImage,
  },
  {
    id: 6,
    name: 'Shalimar Heights, Delhi',
    area: '72000 Sqft.',
    image: demoImage,
  },
];
---

<section id="projects" class="w-full">
  <div class="bg-secondary md:py-24 py-16 z-0">
    <div class="md:px-4 max-w-6xl mx-auto embla">
      <div class="flex px-4 items-center justify-between mb-12">
        <h2 class="lg:text-4xl text-3xl font-bold text-white">
          Shaping Skylines with excellence
        </h2>
        <div class="items-center gap-2 hidden md:flex">
          <button
            class="embla-prev text-white hover:text-secondary-light disabled:cursor-not-allowed transition-colors disabled:text-white/50 cursor-pointer"
            aria-label="Previous slide"
          >
            <CircleArrowLeft class="size-10 stroke-[1.5]" />
          </button>
          <button
            class="embla-next text-white hover:text-secondary-light disabled:cursor-not-allowed transition-colors disabled:text-white/50 cursor-pointer"
            aria-label="Next slide"
          >
            <CircleArrowRight class="size-10 stroke-[1.5]" />
          </button>
        </div>
      </div>

      <div class="embla-viewport">
        <div class="embla-container">
          {
            properties.map((property) => (
              <div class="embla-slide reveal w-64 first-of-type:md:pl-4 md:pl-6 pl-4 last-of-type:pr-4">
                <div class="aspect-[8/9] overflow-hidden rounded-xl bg-radial from-indigo-500 to-indigo-600">
                  <Image
                    src={property.image}
                    alt={property.name}
                    loading="lazy"
                    decoding="async"
                    widths={[288, 320, 384]}
                    sizes="(max-width: 640px) 288px, (max-width: 768px) 320px, 384px"
                    format="webp"
                    class="h-full w-full object-cover hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <div class="p-2">
                  <h3 class="text-md font-semibold text-white">
                    {property.name}
                  </h3>
                  <p class="text-gray-100 font-medium text-sm">
                    {property.area}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
  <Marquee />
</section>
