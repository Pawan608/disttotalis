---
import { CircleArrowLeft, CircleArrowRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import demoImage from '../assets/building.jpeg';
import demoBrand from '../assets/hindalco-logo.svg';
import demoBuilding from '../assets/hotel-building.jpg';
import demoBuilding1 from '../assets/building-placeholder.jpg';

// Property data array
const properties = [
  {
    id: 1,
    name: 'Supreme, Pune',
    area: '88544 Sqft.',
    image: demoBuilding1,
  },
  {
    id: 2,
    name: 'Shalimar Mannat, Lucknow',
    area: '88544 Sqft.',
    image: demoBuilding,
  },
  {
    id: 3,
    name: 'Eldeco Luxa',
    area: '30000 Sqft.',
    image: demoImage,
  },
  {
    id: 4,
    name: 'Natura by One Oak, Lucknow',
    area: '75114 Sqft.',
    image: demoImage,
  },
  {
    id: 5,
    name: 'Supreme Elite, Mumbai',
    area: '95000 Sqft.',
    image: demoImage,
  },
  {
    id: 6,
    name: 'Shalimar Heights, Delhi',
    area: '72000 Sqft.',
    image: demoImage,
  },
];

// Brand logos for marquee
const brands = [demoBrand, demoBrand, demoBrand];
---

<section id="projects" class="w-full">
  <!-- Properties Section -->
  <div class="bg-secondary md:py-24 py-16 px-4 z-0">
    <div class="px-4 max-w-6xl mx-auto">
      <!-- Header with Navigation -->
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Shaping Skylines with excellence
        </h2>
        <div class="flex items-center gap-3">
          <button
            id="project-prev"
            class="text-white hover:text-secondary-light disabled:cursor-not-allowed transition-colors disabled:text-white/50 cursor-pointer"
            aria-label="Previous slide"
          >
            <CircleArrowLeft size={48} stroke-width={1.5} />
          </button>
          <button
            id="project-next"
            class="text-white hover:text-secondary-light disabled:cursor-not-allowed transition-colors disabled:text-white/50 cursor-pointer"
            aria-label="Next slide"
          >
            <CircleArrowRight size={48} stroke-width={1.5} />
          </button>
        </div>
      </div>

      <!-- Embla Carousel Container -->
      <div class="embla" id="embla">
        <div class="embla__container">
          {
            properties.map((property) => (
              <div class="embla__slide">
                <div class="w-64 flex-shrink-0">
                  <div class="aspect-[8/9] overflow-hidden">
                    <div class="rounded-xl reveal w-full bg-radial from-indigo-500 to-indigo-600 overflow-hidden h-full">
                      <Image
                        src={property.image}
                        alt={property.name}
                        loading={'lazy'}
                        decoding="async"
                        layout="full-width"
                        format="avif"
                        class="h-full object-cover hover:scale-105 transition-transform duration-400"
                      />
                    </div>
                  </div>
                  <div class="p-2">
                    <h5 class="text-md font-semibold text-white">
                      {property.name}
                    </h5>
                    <p class="text-gray-100 font-medium text-sm">
                      {property.area}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Smooth Marquee Section -->
  <div class="h-28 z-10 flex items-center relative">
    <!-- Trust Badge -->
    <span
      class="absolute z-20 top-0 rounded-full backdrop-blur-sm bg-white px-8 py-2 -translate-y-6 -translate-x-1/2 left-1/2 text-center text-secondary text-md lg:text-lg font-light shadow-sm drop-shadow-xs text-nowrap"
    >
      Our Trusted Project
    </span>
    <div class="marquee-container relative w-full pt-4">
      <div class="marquee-content">
        {
          brands.map((brand, index) => (
            <Image
              src={brand}
              alt="Brand logo"
              class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity duration-300 flex-shrink-0 mx-8"
            />
          ))
        }
      </div>
      <div class="marquee-content" aria-hidden="true">
        {
          brands.map((brand, index) => (
            <Image
              src={brand}
              alt="Brand logo"
              class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity duration-300 flex-shrink-0 mx-8"
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from 'embla-carousel';

  document.addEventListener('DOMContentLoaded', () => {
    const emblaNode = document.getElementById('embla');
    const prevBtn = document.getElementById('project-prev');
    const nextBtn = document.getElementById('project-next');

    if (!emblaNode || !prevBtn || !nextBtn) return;

    // Embla options
    const options = {
      align: 'start' as const,
      slidesToScroll: 1,
      containScroll: 'trimSnaps' as const,
      dragFree: false,
      loop: false,
      skipSnaps: false,
      // Responsive breakpoints
      breakpoints: {
        '(min-width: 768px)': { slidesToScroll: 2 },
        '(min-width: 1024px)': { slidesToScroll: 3 },
      },
    };

    // Initialize Embla with autoplay plugin (optional)
    const embla = EmblaCarousel(emblaNode, options);

    // Button functionality
    const updateButtons = () => {
      const prevButton = prevBtn as HTMLButtonElement;
      const nextButton = nextBtn as HTMLButtonElement;

      prevButton.disabled = !embla.canScrollPrev();
      nextButton.disabled = !embla.canScrollNext();
    };

    prevBtn.addEventListener('click', () => {
      embla.scrollPrev();
    });

    nextBtn.addEventListener('click', () => {
      embla.scrollNext();
    });

    // Update buttons on slide change
    embla.on('select', updateButtons);
    embla.on('init', updateButtons);

    // Keyboard navigation
    emblaNode.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        embla.scrollPrev();
      } else if (e.key === 'ArrowRight') {
        embla.scrollNext();
      }
    });
  });
</script>

<style>
  .embla {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    gap: 1.5rem;
  }

  .embla__slide {
    flex: 0 0 auto;
    min-width: 0;
  }
</style>
