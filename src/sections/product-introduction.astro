---
import Button from '../components/button.astro';
import { Star } from '@lucide/astro';
import { getImage } from 'astro:assets';
import { cx } from '../scripts/cx';
import type { Product } from '../lib/products';

type Props = {
  product: Product;
};

const { product } = Astro.props;

const images = await Promise.all(
  product.images.map((i) =>
    getImage({
      src: i,
      widths: [512, 768, 960],
      format: 'webp',
    })
  )
);

const thumbs = await Promise.all(
  product.images.map((i) =>
    getImage({ src: i, widths: [96, 128], format: 'webp' })
  )
);

const productData = { ...product, thumbs, images };
---

<section id="product-introduction">
  <div class="max-w-6xl mt-8 mx-auto px-4 grid md:grid-cols-2 gap-16">
    <div class="space-y-8">
      <div
        class="aspect-square w-full max-w-lg mx-auto rounded-2xl overflow-hidden border border-neutral-200 shadow-md relative"
      >
        <img
          id="main-image"
          fetchpriority="high"
          src={productData.images[0].src}
          srcset={productData.images[0].srcSet.values
            .map((v) => `${v.url} ${v.descriptor}`)
            .join(', ')}
          alt={`${productData.name} Image`}
          sizes="(max-width: 768px) 99vw, 50vw"
          loading="eager"
          class="w-full h-full object-cover transition-opacity duration-300"
        />
        <div
          class="absolute top-4 left-4 bg-primary inset-shadow-sm inset-primary-light text-white text-sm px-2 py-0.5 rounded-md"
        >
          BIS Certified
        </div>
      </div>

      <!-- Thumbnail Gallery -->
      <div class="flex gap-4 justify-center">
        {
          productData.thumbs.map((img, i: number) => (
            <button
              class={cx(
                'thumbnail-btn aspect-square w-16 rounded-lg overflow-hidden transition-all duration-300',
                'hover:brightness-75 ring-2 ring-offset-2 cursor-pointer',
                i === 0 ? 'ring-primary' : 'ring-transparent'
              )}
              data-src={productData.images[i].src}
              data-srcset={productData.images[i].srcSet.values
                .map((v) => `${v.url} ${v.descriptor}`)
                .join(', ')}
              data-alt={`${productData.name} view ${i + 1}`}
              data-index={i}
              aria-label={`View ${i + 1} of ${productData.name}`}
            >
              <img
                src={img.src}
                srcset={img.srcSet.values
                  .map((v) => `${v.url} ${v.descriptor}`)
                  .join(', ')}
                sizes="(max-width: 768px) 96px, 128px"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
                alt=""
              />
            </button>
          ))
        }
      </div>
    </div>

    <!-- Product Information -->
    <div class="flex flex-col justify-between space-y-8">
      <div class="space-y-4">
        <!-- Product Header -->
        <div class="space-y-4">
          <p
            class="uppercase text-xs text-neutral-500 border border-neutral-400 px-2 bg-neutral-50 rounded-full max-w-fit leading-none py-0.5"
          >
            Sliding Window
          </p>
          <h1 class="text-4xl font-bold text-neutral-900">{product.name}</h1>
          <p class="text-base text-neutral-600">{product.description}</p>
        </div>

        <!-- Quality Badge -->
        <div
          class="p-4 flex gap-2 items-center border border-green-200 bg-primary/5 rounded-2xl text-green-600"
        >
          <Star class="w-6 h-6 mt-1 fill-current stroke-transparent" />
          <article>
            <h2 class="font-semibold text-green-700">
              Premium Quality Assured
            </h2>
            <p class="text-sm">
              Tested & Certified for Indian Climate Conditions
            </p>
          </article>
        </div>

        <!-- Key Features -->
        <div class="space-y-4">
          <h2 class="text-2xl font-semibold">Key Features</h2>
          <div class="grid grid-cols-1 gap-2">
            {
              productData.features.map((feature) => (
                <article class="flex inset-shadow-xs inset-shadow-white bg-[#fdfdfd] p-4 items-start gap-4 rounded-2xl shadow-xs border border-neutral-200">
                  <div class="bg-gradient-to-br from-secondary/5 to-secondary/20 border border-secondary/15 rounded-lg p-2 self-center">
                    <feature.icon class="w-6 h-6 stroke-secondary" />
                  </div>
                  <div>
                    <p class="text-base font-semibold text-neutral-800">
                      {feature.title}
                    </p>
                    <p class="text-sm text-neutral-500">{feature.text}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex gap-4">
        <Button
          variant="primary"
          color="blue"
          link="/contact"
          classList="transition-smooth grow"
        >
          Request Quote
        </Button>
        <Button
          variant="secondary"
          color="blue"
          classList="transition-smooth grow skip-to-download-brochure"
        >
          Download Catalog
        </Button>
      </div>
    </div>
  </div>

  <!-- Statistics -->
  <!-- <div
    class="max-w-6xl mx-auto px-4 mt-16 mb-8 justify-items-center grid grid-cols-2 md:grid-cols-4 gap-4 text-center"
  >
    {
      product.stats.map((stat) => (
        <div class="border max-w-64 w-full glow-card overflow-hidden border-neutral-200 shadow py-8 rounded-2xl flex flex-col items-center hover:shadow-lg">
          <div class="w-12 z-10 aspect-square flex items-center mb-2 justify-center rounded-xl bg-gradient from-secondary-light to-secondary bg-gradient-to-br border border-secondary-light">
            <stat.icon class="size-8 stroke-[1.7] stroke-white" />
          </div>
          <p class="text-2xl font-bold text-secondary">{stat.value}</p>
          <p class="text-sm text-neutral-500">{stat.label}</p>
        </div>
      ))
    }
  </div> -->
</section>
