---
import { Image } from 'astro:assets';
import Button from '../components/button.astro';
import totalisLogo from '../assets/totalis.png';
import abgLogo from '../assets/abg-logo-no-bg.png';
---

<section
  class="px-4 max-w-7xl mx-auto py-12 md:py-20 flex flex-col lg:flex-row items-center justify-between gap-10"
>
  <div class="flex-1">
    <h2
      class="text-[clamp(1.75rem,4vw,2.75rem)] text-gray-900 font-bold leading-tight reveal"
    >
      Let’s Discuss your Project with us
    </h2>
    <div class="flex flex-wrap gap-4 mt-6">
      <Button
        link="/contact"
        variant="primary"
        reveal={true}
        animationDelay="100"
        classList="font-semibold">Get in Touch</Button
      >
      <!-- <Button
        link="/consultation"
        variant="outline"
        reveal={true}
        animationDelay="150"
        classList="font-semibold">Book a Free Consultation</Button
      >-->
    </div>
  </div>

  <div
    class="flex-1 lg:flex hidden drop-shadow-md rounded-2xl justify-center w-full"
  >
    <div
      class="w-full max-w-md flex md:flex-row rounded-2xl p-6 items-center gap-8"
    >
      <div class="grow inline-flex md:justify-start w-4/5 justify-center">
        <Image
          src={totalisLogo}
          format="avif"
          alt="Totalis Brand Logo"
          layout="constrained"
        />
      </div>
      <div class="inline-flex w-1/5 md:justify-end justify-center">
        <Image
          src={abgLogo}
          format="avif"
          alt="Aditya Birla Logo"
          layout="constrained"
        />
      </div>
    </div>
  </div>
</section>
