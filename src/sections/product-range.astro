---
import { CircleArrowLeft, CircleArrowRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import SectionHeading from '../components/section-heading.astro';

import { productCategories, productsByCategory } from '../lib/products';
---

<section id="product-range" class="w-full mb-8">
  <div class="px-4 max-w-6xl mx-auto flex pt-8 flex-col items-center">
    <div class="text-center">
      <SectionHeading
        title="Our Product Range"
        description="Every detail engineered for performance, durability, and design."
      />
    </div>
  </div>
  <div class="tab-group my-8 w-full space-y-8">
    <div class="flex justify-center">
      <div
        class="tab-glider rounded-full flex gap-2 bg-neutral-100 relative px-1 before:bg-secondary before:shadow-secondary/60 before:rounded-full"
      >
        {
          productCategories.map((tab, i) => (
            <button
              class="tab-button text-sm text-neutral-600 data-[active=true]:text-white transition-all duration-300 px-4 lg:px-6 lg:py-4 cursor-pointer hover:text-neutral-900 py-3 grow leading-none rounded-md data-[active=true]:font-medium"
              data-tab={tab.id}
              data-active={i === 0}
            >
              {tab.name}
            </button>
          ))
        }
      </div>
    </div>

    <div class="tab-content">
      {
        Object.entries(productsByCategory).map(([key, products]) => (
          <div
            class={
              'tab-pane embla space-y-4 md:space-y-8' +
              (key === 'sliding' ? ' tab-active' : '')
            }
            data-tab={key}
          >
            <div class="hidden md:flex max-w-6xl mx-auto gap-2 justify-end px-4">
              <button
                class="embla-prev text-neutral-600 hover:text-primary disabled:cursor-not-allowed transition-colors disabled:text-neutral-400 cursor-pointer"
                aria-label="Previous product"
              >
                <CircleArrowLeft class="size-10 stroke-[1.5]" />
              </button>
              <button
                class="embla-next text-neutral-600 hover:text-primary disabled:cursor-not-allowed transition-colors disabled:text-neutral-400 cursor-pointer"
                aria-label="Next product"
              >
                <CircleArrowRight class="size-10 stroke-[1.5]" />
              </button>
            </div>

            <div class="embla-viewport">
              <div class="embla-container px-4">
                {products.map((p) => (
                  <div class="flex-none embla-slide md:w-sm w-xs pl-4 lg:pl-6 last:mr-4">
                    <a href={`product/${p.slug}`} class="group block">
                      <div class="relative aspect-video rounded-2xl overflow-hidden mb-4">
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-secondary/50 z-10" />
                        <Image
                          src={p.images[0]}
                          alt={p.name}
                          loading="lazy"
                          decoding="async"
                          widths={[384, 448]}
                          sizes={'(max-width: 768px) 384px, 448px'}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        />
                        <div class="absolute bottom-4 left-4 z-20">
                          <h3 class="text-white text-lg md:text-xl font-bold mb-1">
                            {p.name}
                          </h3>
                          <p class="text-white/80 text-xs md:text-sm max-w-[calc(100%-60px)]">
                            {p.shortDescription}
                          </p>
                        </div>
                        <div class="absolute bottom-4 right-4 z-20">
                          <CircleArrowRight class="text-white group-hover:text-white transition-colors duration-300 size-10 stroke-[1.5]" />
                        </div>
                        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10" />
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
