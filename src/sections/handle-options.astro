---
import { Image } from 'astro:assets';
import SectionHeading from '../components/section-heading.astro';
import type { ProductItem } from '../types';

type Props = {
  product: ProductItem;
};

const { product } = Astro.props;
---

<section class="pt-16" id="handle-options">
  <div class="max-w-6xl mx-auto px-4 text-center mb-12">
    <SectionHeading
      title="Handle Options"
      description="Select from our premium handle options designed for functionality, security, and aesthetics"
    />
  </div>

  <div class="max-w-6xl mx-auto flex flex-wrap gap-6 px-4 justify-center">
    {
      product.handleOptions.map(({ title, image, alt }) => (
        <div class="relative">
          <article
            class="w-xs transition-all group duration-300 rounded-2xl overflow-hidden shadow-sm border border-neutral-200 bg-white
                        hover:scale-105 hover:shadow-xl"
          >
            <div class="h-48 overflow-hidden">
              <Image
                src={image}
                alt={alt}
                class="w-full h-full object-cover scale-105 transition duration-300 group-hover:scale-100"
                loading="lazy"
              />
            </div>
            <div class="p-3 text-center">
              <h3 class="font-semibold text-sm text-neutral-900">{title}</h3>
            </div>
          </article>
        </div>
      ))
    }
  </div>
</section>

<style></style>
