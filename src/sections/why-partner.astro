---
import { Image } from 'astro:assets';
import totalisEmployeesImg from '../assets/totalis-employees.png';
---

<section
  id="why-partner"
  class="px-4 max-w-6xl mx-auto mt-8 lg:mt-16 py-8 lg:py-16"
>
  <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
    <div class="flex flex-col gap-4">
      <h2
        class="text-[clamp(1.75rem,4vw,2.25rem)] text-neutral-800 font-semibold reveal"
      >
        Why Partner with Totalis as a Fabricator?
      </h2>
      <p>
        At Totalis, we believe in empowering our fabricator partners with
        everything they need to succeed. When you choose to work with us, you
        don't just get access to premium aluminium systems, you gain a
        partnership built on trust, technology, and flexibility.
      </p>

      <a
        href="/contact"
        class="underline text-cyan-600 underline-offset-4
      hover:text-cyan-800 active:text-blue-700 visited:text-purple-800 w-fit"
        >Contact Us
      </a>
    </div>

    <div class="flex justify-center md:justify-end">
      <Image
        src={totalisEmployeesImg}
        format="webp"
        quality={95}
        decoding={'async'}
        priority={true}
        fetchpriority={'high'}
        layout="constrained"
        fit="cover"
        widths={[320, 480, 640]}
        sizes="(max-width: 768px) 100vw, 640px"
        loading={'eager'}
        alt="Totalis Employees"
        class="rounded-lg"
      />
    </div>
  </div>
</section>
