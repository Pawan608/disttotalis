---
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';

import '../styles/global.css';
import ContactUsForm from '../components/contact-us-form.astro';

const { title, htmlClassName, description } = Astro.props;
---

<html lang="en" class={htmlClassName}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/totalis-favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <!-- For Canonical SEO -->
    <link
      rel="canonical"
      href={`https://totalis.hindalco.com${Astro.url.pathname}`}
    />
    <!-- TODO: Add canonical to skip from SEO score split -->

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:url"
      content={`https://totalis.hindalco.com${Astro.url.pathname}`}
    />
    <meta
      property="og:image"
      content="https://totalis.hindalco.com/og-image.jpg"
    />
    <!-- TODO: Deploy CDN with a original totalis logo which must be used here -->
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />

    <title>{title}</title>
    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <ContactUsForm />
  </body>
  <script>
    import {
      initContactForm,
      initContactFormTriggers,
    } from '../scripts/contact-form';

    document.addEventListener('DOMContentLoaded', () => {
      initContactFormTriggers();
      initContactForm({ contactFormPrefix: 'cmf', formId: 'contact-form' });
    });
  </script>
</html>
