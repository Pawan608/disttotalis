---
import {
  X,
  CheckCircle,
  User,
  Mail,
  Phone,
  MapPin,
  Target,
  Briefcase,
  MapIcon,
  DownloadIcon,
} from '@lucide/astro';
import Button from './button.astro';
import FormElement from '../components/input.astro';
---

<div
  class="fixed hidden inset-0 z-50 items-center w-full justify-center bg-black/70 backdrop-blur-sm transition-all duration-300 p-4 md:p-6 overflow-hidden"
  id="contact-form-modal"
>
  <div
    class="relative max-w-3xl w-full bg-white rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto"
  >
    <div
      class="sticky top-0 bg-white rounded-t-2xl border-b border-neutral-100 sm:p-6 p-4 pb-2"
    >
      <button
        class="close-contact-form-trigger absolute top-4 right-4 stroke-neutral-400 hover:stroke-neutral-600 focus:outline-none transition-colors cursor-pointer"
      >
        <X class="sm:size-6 size-5" />
      </button>

      <h2
        class="sm:text-2xl text-xl font-semibold text-neutral-800 sm:mb-2 mb-1"
      >
        Let's Know You First
      </h2>
      <!-- <p class="text-neutral-600 sm:text-base text-sm">
            We hope to keep you in our.. 
      </p> -->
    </div>

    <div class="p-4 sm:p-8 pt-4" id="form-container">
      <form id="contact-form" class="space-y-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <FormElement
            id="fullName"
            type="text"
            pattern="^[a-zA-Z \.]{3,50}$"
            patternTitle="Please enter a valid name"
            placeholder="John Doe"
            minLength={3}
            required={true}
          >
            <User slot={'labelIcon'} class="size-3" />
            <span slot="labelText">Full Name</span>
          </FormElement>

          <FormElement
            id="email"
            type="email"
            placeholder="johndoe@gmail.com"
            required={true}
          >
            <Mail slot={'labelIcon'} class="size-3" />
            <span slot="labelText">Email Address</span>
          </FormElement>

          <FormElement
            id="whatsappNumber"
            type="tel"
            pattern="[0-9]{10}"
            patternTitle="Please enter 10 digit whatsapp number"
            placeholder="+91 XXXXXXXXXX"
            required={true}
          >
            <Phone slot={'labelIcon'} class="size-3" />
            <span slot="labelText">Whatsapp Number</span>
          </FormElement>

          <FormElement
            id="pincode"
            type="text"
            pattern="[0-9]{6}"
            patternTitle="Enter 6 digit pincode"
            placeholder="Enter your pincode"
            required={true}
          >
            <MapPin slot={'labelIcon'} class="size-3" />
            <span slot="labelText">Pincode</span>
          </FormElement>

          <div class="grid grid-cols-2 gap-2">
            <FormElement
              id="state"
              type="select"
              selectOptions={[
                {
                  value: '',
                  displayValue: 'Select your state',
                  selected: true,
                },
              ]}
              disabled
            >
              <MapIcon slot="labelIcon" class="size-3" />
              <span slot="labelText">State</span>
            </FormElement>

            <FormElement
              id="city"
              type="select"
              selectOptions={[
                {
                  value: '',
                  displayValue: 'Select your city',
                  selected: true,
                },
              ]}
              disabled
            >
              <MapPin slot={'labelIcon'} class="size-3" />
              <span slot="labelText">City</span>
            </FormElement>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <FormElement
              id="intent"
              type="select"
              selectOptions={[
                { value: '', displayValue: 'Select your intent' },

                {
                  value: 'Buy a Totalis Product',
                  displayValue: 'Buy a Totalis Product',
                },
                {
                  value: 'Become a Totalis Partner',
                  displayValue: 'Become a Totalis Partner',
                },
              ]}
              required
            >
              <span slot="labelText">I am looking to...</span>
              <Target slot="labelIcon" class="size-3" />
            </FormElement>
            <FormElement
              type="select"
              selectOptions={[
                {
                  value: '',
                  displayValue: 'Select your role',
                  selected: true,
                },
                { value: 'Distributor', displayValue: 'Distributor' },
                {
                  value: 'Individual Home Owner',
                  displayValue: 'Individual Home Owner',
                },
                {
                  value: 'Architect/Interior Decorator/Consultant',
                  displayValue: 'Architect/Interior Decorator/Consultant',
                },
              ]}
              id="role"
              required
            >
              <span slot="labelText">I am a...</span>
              <Briefcase slot="labelIcon" class="size-3" />
            </FormElement>
          </div>
        </div>

        <!-- Terms & Conditions -->
        <div class="pt-4 border-t border-neutral-100">
          <label class="flex items-start gap-2 cursor-pointer">
            <input
              type="checkbox"
              required
              class="mt-1 size-3 accent-primary-dark border-neutral-300 rounded focus:ring-primary focus:ring-2"
            />
            <span class="text-xs text-neutral-600 leading-relaxed">
              I agree to the <a
                href="/privacy"
                class="text-primary hover:underline font-medium"
                >Privacy Policy</a
              >
              and <a
                href="/terms"
                class="text-primary hover:underline font-medium"
                >Terms & Conditions</a
              > of Totalis
            </span>
          </label>
        </div>

        <div class="flex justify-end items-center gap-2">
          <Button
            classList="skip-to-download-brochure py-1 text-sm text-neutral-600 rounded-lg transition-smooth"
            variant="default">Skip</Button
          >
          <Button
            variant="primary"
            type="submit"
            classList="py-1 text-sm rounded-lg transition-smooth"
            >Submit Application</Button
          >
        </div>
      </form>
    </div>
  </div>
  <div class="p-8 text-center hidden" id="success-container">
    <div class="max-w-md mx-auto">
      <div
        class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4"
      >
        <CheckCircle class="w-8 h-8 text-green-600" />
      </div>
      <h3 class="text-xl font-semibold text-neutral-900 mb-2">Thank You!</h3>
      <p class="text-neutral-600 mb-6">
        Thanks for your time. We'll get back to you soon!
      </p>
      <Button variant="primary" classList="transition-smooth">
        <DownloadIcon class="size-4" />
        Download Brochure</Button
      >
    </div>
  </div>
</div>
