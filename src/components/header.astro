---
import { Image } from 'astro:assets';
import totalisLogo from '../assets/logos/totalis.png';
import { X } from '@lucide/astro';
import abgLogo from '../assets/logos/abg-logo-no-bg.png';

const links = [
  { href: '/', label: 'Home', desktop: false },
  { href: '/products', label: 'Products', desktop: true, hasSub: true },
  { label: 'Brochure', desktop: true },
  {label:'About Us', href:'/about', desktop:true},
  { href: '/why', label: 'Why Totalis', desktop: true },
  { href: '/locate-us', label: 'Locate us', desktop: true },
];

import {
  productsByCategory,
  productCategoryToCategoryTitle,
} from '../lib/products';

const { pathname } = Astro.url;
---

<header class="z-30 sticky top-0 w-full">
  <nav
    class="h-16 bg-[rgba(255,255,255,0.95)] drop-shadow-sm backdrop-blur-sm px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <a class="flex flex-row items-center" href="/" aria-label="Totalis Home">
      <Image
        src={totalisLogo}
        loading={'eager'}
        format="webp"
        width={128}
        alt="Totalis Brand Logo"
        layout="constrained"
        height={36}
      />
    </a>

    <!-- Mobile menu button -->
    <div class="md:hidden flex items-center gap-2">
      <Image
        src={abgLogo}
        format="webp"
        loading={'eager'}
        widths={[48, 64]}
        sizes="(max-width: 768px) 48px, 64px"
        alt="Aditya Birla Group Brand Logo"
        layout="constrained"
        height={36}
      />

      <button
        id="menu-toggle"
        class="text-neutral-700 focus:outline-none transition-transform duration-300 hover:scale-110"
        aria-label="Toggle menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          class="size-6 stroke-zinc-800"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 9h16.5m-16.5 6.75h16.5"
          />
        </svg>
      </button>
    </div>

    <!-- Desktop Links -->
    <div class="hidden md:flex gap-6 items-center">
      <ul class="flex gap-2 text-neutral-700 font-medium">
        {
          links.map(({ href, label, desktop, hasSub }) => {
            if (!desktop) return null;

            if (hasSub && label === 'Products') {
              return (
                <li class="relative">
                  <details id="products-dropdown" class="group peer">
                    <summary class="flex items-center justify-between gap-1 cursor-pointer px-3 py-2 text-sm font-medium text-neutral-700 rounded-lg transition hover:bg-neutral-50 hover:text-primary">
                      Products
                      <svg
                        class="w-4 h-4 transition-transform group-open:rotate-180"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M19 9l-7 7-7-7"
                        />
                      </svg>
                    </summary>

                    <div class="absolute right-0 mt-2 w-56 bg-white overflow-hidden shadow-xl rounded-2xl z-30">
                      <ul class="py-2">
                        {Object.entries(productsByCategory).map(
                          ([key, products]) => (
                            <li class="group relative">
                              <details class="group">
                                <summary class="flex justify-between items-center px-4 py-2 text-sm text-neutral-700 cursor-pointer hover:bg-neutral-50">
                                  {productCategoryToCategoryTitle[key]}
                                  <svg
                                    class="w-4 h-4 transition-transform group-open:rotate-90"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M9 5l7 7-7 7"
                                    />
                                  </svg>
                                </summary>

                                <ul class="pl-4 py-1 space-y-1 bg-white">
                                  {products.map(({ slug, name }) => (
                                    <li>
                                      <a
                                        href={'/product/' + slug}
                                        class="block px-4 py-1 text-sm text-neutral-700 hover:bg-neutral-100 rounded"
                                      >
                                        {name}
                                      </a>
                                    </li>
                                  ))}
                                </ul>
                              </details>
                            </li>
                          )
                        )}
                      </ul>
                    </div>
                  </details>
                </li>
              );
            }

            return (
              <li>
                {!href ? (
                  <button
                    class="block px-3 py-2 text-sm transition-colors duration-200 text-neutral-700 hover:text-primary cursor-pointer contact-form-trigger"
                  >
                    {label}
                  </button>
                ) : (
                  <a
                    href={href}
                    class={`block px-3 py-2 text-sm transition-colors duration-200 ${
                      pathname === href ? 'text-primary font-semibold' : 'text-neutral-700 hover:text-primary'
                    }`}
                  >
                    {label}
                  </a>
                )}
              </li>
            );
          })
        }
      </ul>

      <Image
        src={abgLogo}
        format="webp"
        widths={[48, 64]}
        sizes="(max-width: 768px) 48px, 64px"
        loading={'eager'}
        alt="Aditya Birla Group Brand Logo"
        layout="constrained"
        class="w-10"
      />
    </div>
  </nav>

  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-white/75 backdrop-blur-3xl z-50 transform -translate-y-full transition-transform duration-500 ease-in-out md:hidden overflow-y-auto"
  >
    <!-- Fixed Header in Mobile Menu -->
    <div class="sticky top-0 bg-white/90 backdrop-blur-sm z-10 px-6 py-4 flex justify-between items-center border-b border-neutral-200">
      <a href="/" aria-label="Totalis Home">
        <Image
          src={totalisLogo}
          format="webp"
          loading={'eager'}
          widths={[128, 160]}
          sizes="128px"
          alt="Totalis Brand Logo"
          layout="constrained"
          class="w-32"
        />
      </a>

      <button
        id="menu-close"
        class="text-neutral-700 hover:text-neutral-900 transition-colors duration-200"
        aria-label="Close menu"
      >
        <X class="size-6" stroke-width={1.5} />
      </button>
    </div>

    <!-- Scrollable Menu Content -->
    <div class="px-6 py-8 pb-20">
      <nav class="space-y-6">
        <a href="/" class="block text-2xl font-light hover:text-primary transition-colors">
          Home
        </a>
        <!-- Products Section -->
        <div class="space-y-4">
          <span class="block text-2xl font-light text-neutral-900 mb-3">
            Products
          </span>
          {
            Object.entries(productsByCategory).map(([key, products]) => (
              <div class="mb-4">
                <span class="block text-lg font-medium text-neutral-700 mb-2">
                  {productCategoryToCategoryTitle[key]}
                </span>
                <ul class="pl-4 space-y-2">
                  {products.map(({ slug, name }) => (
                    <li>
                      <a 
                        href={'/product/' + slug} 
                        class="block text-base font-light text-neutral-600 hover:text-primary transition-colors py-1"
                      >
                        {name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>

                
        <a href="/why" class="block text-2xl font-light hover:text-primary transition-colors">
          Why Totalis
        </a>

        <a href="/about" class="block text-2xl font-light hover:text-primary transition-colors">
          About Us
        </a>

        <a href="/locate-us" class="block text-2xl font-light hover:text-primary transition-colors">
          Locate Us
        </a>

        <button class="block text-2xl font-light text-left contact-form-trigger hover:text-primary transition-colors">
          Brochure
        </button>
      </nav>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const closeBtn = document.getElementById('menu-close') as HTMLButtonElement | null;
    const overlay = document.getElementById('mobile-overlay') as HTMLDivElement | null;

    const openMenu = () => {
      if (!overlay) return;

      overlay.classList.remove('-translate-y-full');
      overlay.classList.add('translate-y-0');
      document.body.classList.add('overflow-hidden');

      // Reset scroll position to top
      overlay.scrollTop = 0;

      const menuItems = overlay.querySelectorAll<HTMLElement>('nav a, nav button, nav span');
      menuItems.forEach((item, index) => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(20px)';
        setTimeout(() => {
          item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        }, index * 50 + 100);
      });
    };

    const closeMenu = () => {
      if (!overlay) return;

      overlay.classList.add('-translate-y-full');
      overlay.classList.remove('translate-y-0');
      document.body.classList.remove('overflow-hidden');
    };

    toggleBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);

    if (overlay) {
      const menuLinks = overlay.querySelectorAll<HTMLAnchorElement>('nav a');
      menuLinks.forEach(link => link.addEventListener('click', closeMenu));

      const mobileBrochureBtn = overlay.querySelector<HTMLButtonElement>(
        'nav button.contact-form-trigger'
      );

      mobileBrochureBtn?.addEventListener('click', () => {
        const desktopBrochureBtn =
          document.querySelector<HTMLButtonElement>('.contact-form-trigger');

        desktopBrochureBtn?.click?.();
        closeMenu();
      });
    }

    // Close desktop dropdown on outside click
    const productsDropdown = document.getElementById('products-dropdown') as HTMLDetailsElement | null;

    if (productsDropdown) {
      document.addEventListener('click', (event) => {
        if (!productsDropdown.contains(event.target as Node)) {
          productsDropdown.open = false;
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && productsDropdown.open) {
          productsDropdown.open = false;
        }
      });
    }

    // Close mobile menu on Escape key
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && overlay?.classList.contains('translate-y-0')) {
        closeMenu();
      }
    });
  });
</script>

<style>
  @keyframes slideDown {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Smooth scrolling for mobile menu */
  #mobile-overlay {
    -webkit-overflow-scrolling: touch;
  }

  /* Better touch targets for mobile */
  @media (max-width: 768px) {
    #mobile-overlay nav a,
    #mobile-overlay nav button {
      min-height: 44px;
      display: flex;
      align-items: center;
    }
  }
</style>