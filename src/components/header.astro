---

---

<header class="z-20 w-full sticky top-0 bg-[#f7f7f7]/80 backdrop-blur-md">
  <nav
    class="max-w-7xl mx-auto h-16 px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <a href="/" class="text-lg font-semibold">Totalis.</a>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden text-gray-700 focus:outline-none"
      aria-label="Toggle menu"
    >
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Links -->
    <ul
      id="mobile-menu"
      class="hidden md:flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-6 text-gray-600 font-medium absolute md:static bg-white w-full left-0 top-full md:w-auto md:bg-transparent px-4 md:px-0 shadow md:shadow-none z-50"
    >
      <li>
        <a
          href="/"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >Home</a
        >
      </li>
      <li>
        <a
          href="/about"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >About</a
        >
      </li>
      <li>
        <a
          href="/contact"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >Contact</a
        >
      </li>
    </ul>
  </nav>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const toggleBtn = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggleBtn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    });
  </script>
</header>
