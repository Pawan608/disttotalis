---
import { Image } from 'astro:assets';
import totalisLogo from '../assets/totalis.png';
import { X } from '@lucide/astro';
import abgLogo from '../assets/abg-logo.png';

const links = [
  { href: '/', label: 'Home' },
  { href: '/why', label: 'Why Totalis' },
  { href: '/products', label: 'Products' },
  { href: '/brochure', label: 'Brochure' },
];
---

<header class="z-20 w-full fixed top-2 lg:top-4">
  <nav
    class="h-12 mx-auto w-7xl max-w-[calc(100dvw-1.25rem)] bg-[rgba(255,255,255,0.925)] outline-1 outline-[rgba(255,255,255,0.9)] drop-shadow-sm rounded-2xl backdrop-blur-md px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <div class="flex flex-row items-center">
      <Image
        src={totalisLogo}
        format="avif"
        alt="Totalis Brand Logo"
        layout="constrained"
        class="w-28"
      />
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden text-gray-700 focus:outline-none transition-transform duration-300 hover:scale-110"
      aria-label="Toggle menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        class="size-6 stroke-zinc-800"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
      </svg>
    </button>

    <!-- Desktop Links -->
    <ul class="hidden md:flex flex-row space-x-6 text-gray-600 font-medium">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs transition-colors duration-200"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-white/75 backdrop-blur-3xl z-50 transform -translate-y-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <div class="w-32 absolute top-6 left-6">
      <Image
        src={totalisLogo}
        format="avif"
        alt="Totalis Brand Logo"
        layout="constrained"
        class="w-40 opacity-90"
      />
    </div>

    <!-- Close Button -->
    <button
      id="menu-close"
      class="absolute top-6 right-6 text-gray-700 hover:text-gray-900 transition-colors duration-200"
      aria-label="Close menu"
    >
      <X class="size-6" stroke-width={1.25} />
    </button>

    <!-- Menu Content -->
    <div class="flex flex-col justify-center px-10 h-full pb-32 pt-8">
      <!-- Navigation Links -->
      <nav class="text-left space-y-8">
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              class="block text-3xl font-light text-gray-800 hover:text-primary transition-all duration-300 hover:scale-105"
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleBtn = document.getElementById('menu-toggle');
    const closeBtn = document.getElementById('menu-close');
    const overlay = document.getElementById('mobile-overlay');
    const body = document.body;

    function openMenu() {
      overlay.classList.remove('-translate-y-full');
      overlay.classList.add('translate-y-0');
      body.classList.add('overflow-hidden');

      const menuItems = overlay.querySelectorAll('nav a');
      menuItems.forEach((item, index) => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(20px)';
        setTimeout(
          () => {
            item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
          },
          index * 100 + 200
        );
      });
    }

    function closeMenu() {
      overlay.classList.add('-translate-y-full');
      overlay.classList.remove('translate-y-0');
      body.classList.remove('overflow-hidden');
    }

    toggleBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    const menuLinks = overlay.querySelectorAll('nav a');
    menuLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', function (e) {
      if (
        e.key === 'Escape' &&
        !overlay.classList.contains('-translate-y-full')
      ) {
        closeMenu();
      }
    });
  });
</script>

<style>
  @keyframes slideDown {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
