---
import { Image } from 'astro:assets';
import totalisLogo from '../assets/totalis.png';
import { X } from '@lucide/astro';
import abgLogo from '../assets/abg-logo-no-bg.png';

const links = [
  { href: '/', label: 'Home', desktop: false },
  { href: '/why', label: 'Why Totalis', desktop: true },
  { href: '/products', label: 'Products', desktop: true },
  { href: '/brochure', label: 'Brochure', desktop: true },
];

const { pathname } = Astro.url;
---

<header class="z-20 sticky top-0 w-full">
  <nav
    class="h-16 bg-[rgba(255,255,255,0.95)] drop-shadow-sm backdrop-blur-sm px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <a class="flex flex-row items-center" href="/" aria-label="Totalis Home">
      <Image
        src={totalisLogo}
        loading={'eager'}
        format="webp"
        width={128}
        alt="Totalis Brand Logo"
        layout="constrained"
        height={36}
      />
    </a>

    <!-- Mobile menu button -->
    <div class="md:hidden flex items-center gap-2">
      <Image
        src={abgLogo}
        format="webp"
        loading={'eager'}
        widths={[48, 64]}
        sizes={'(max-width: 768px) 48px, 64px'}
        alt={'Aditya Birla Group Brand Logo'}
        layout="constrained"
        height={36}
      />
      <button
        id="menu-toggle"
        class="text-gray-700 focus:outline-none transition-transform duration-300 hover:scale-110"
        aria-label="Toggle menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          class="size-6 stroke-zinc-800"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Links -->
    <div class="hidden md:flex gap-6 items-center">
      <ul class="flex gap-2 text-gray-700 font-medium">
        {
          links.map(
            ({ href, label, desktop }) =>
              desktop && (
                <li>
                  <a
                    href={href}
                    class={`block pl-3 pr-1 relative text-sm before:absolute before:left-0 before:translate-x-1/2 before:top-1/2 before:-translate-y-1/2 before:h-1 before:w-1 before before:rounded-full transition-colors duration-200 
            ${pathname === href ? 'text-primary font-semibold before:bg-primary before:content[""] hover:text-primary-dark hover:underline hover:underline-offset-4 decoration-primary' : 'hover:text-primary hover:underline underline-offset-4 decoration-primary'}`}
                  >
                    {label}
                  </a>
                </li>
              )
          )
        }
      </ul>
      <Image
        src={abgLogo}
        format="webp"
        widths={[48, 64]}
        sizes={'(max-width: 768px) 48px, 64px'}
        loading={'eager'}
        alt={'Aditya Birla Group Brand Logo'}
        layout="constrained"
        class={'w-10'}
      />
    </div>
  </nav>

  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-white/75 backdrop-blur-3xl z-50 transform -translate-y-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <a class="w-32 absolute top-6 left-6" href="/" aria-label="Totalis Home">
      <Image
        src={totalisLogo}
        format="webp"
        loading={'eager'}
        widths={[160, 192]}
        sizes={'(max-width: 768px) 160px, 198px'}
        alt="Totalis Brand Logo"
        layout="constrained"
        class="w-40 opacity-90"
      />
    </a>

    <!-- Close Button -->
    <button
      id="menu-close"
      class="absolute top-6 right-6 text-gray-700 hover:text-gray-900 transition-colors duration-200"
      aria-label="Close menu"
    >
      <X class="size-6" stroke-width={1.25} />
    </button>

    <!-- Menu Content -->
    <div class="flex flex-col justify-center px-10 h-full pb-32 pt-8">
      <!-- Navigation Links -->
      <nav class="text-left space-y-8">
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              class="block text-3xl px-2 font-light text-gray-800 hover:text-primary transition-all transform duration-300 ease-in hover:scale-105"
            >
              <span>{label}</span>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleBtn = document.getElementById('menu-toggle')!;
    const closeBtn = document.getElementById('menu-close')!;
    const overlay = document.getElementById('mobile-overlay')!;

    function openMenu() {
      overlay.classList.remove('-translate-y-full');
      overlay.classList.add('translate-y-0');
      document.body.classList.add('overflow-hidden');

      const menuItems = overlay.querySelectorAll(
        'nav a'
      ) as NodeListOf<HTMLElement>;
      menuItems.forEach((item, index) => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(20px)';
        setTimeout(
          () => {
            item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
          },
          index * 100 + 200
        );
      });
    }

    function closeMenu() {
      overlay.classList.add('-translate-y-full');
      overlay.classList.remove('translate-y-0');
      document.body.classList.remove('overflow-hidden');
    }

    toggleBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    const menuLinks = overlay.querySelectorAll('nav a');
    menuLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (
        e.key === 'Escape' &&
        !overlay.classList.contains('-translate-y-full')
      ) {
        closeMenu();
      }
    });
  });
</script>

<style>
  @keyframes slideDown {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
