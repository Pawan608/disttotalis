---
import { Image } from 'astro:assets';
import totalisLogo from '../assets/logos/totalis.png';
import { X } from '@lucide/astro';
import abgLogo from '../assets/logos/abg-logo-no-bg.png';

const links = [
  { href: '/', label: 'Home', desktop: false },
  { href: '/about', label: 'About Us', desktop: true },
  { href: '/why', label: 'Why Totalis', desktop: true },
  { href: '/products', label: 'Products', desktop: true, hasSub: true },
  { label: 'Brochure', desktop: true },
];

import {
  productsByCategory,
  productCategoryToCategoryTitle,
} from '../lib/products';

const { pathname } = Astro.url;
---

<header class="z-30 sticky top-0 w-full">
  <nav
    class="h-16 bg-[rgba(255,255,255,0.95)] drop-shadow-sm backdrop-blur-sm px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <a class="flex flex-row items-center" href="/" aria-label="Totalis Home">
      <Image
        src={totalisLogo}
        loading={'eager'}
        format="webp"
        width={128}
        alt="Totalis Brand Logo"
        layout="constrained"
        height={36}
      />
    </a>

    <!-- Mobile menu button -->
    <div class="md:hidden flex items-center gap-2">
      <Image
        src={abgLogo}
        format="webp"
        loading={'eager'}
        widths={[48, 64]}
        sizes={'(max-width: 768px) 48px, 64px'}
        alt={'Aditya Birla Group Brand Logo'}
        layout="constrained"
        height={36}
      />
      <button
        id="menu-toggle"
        class="text-neutral-700 focus:outline-none transition-transform duration-300 hover:scale-110"
        aria-label="Toggle menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          class="size-6 stroke-zinc-800"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Links -->
    <div class="hidden md:flex gap-6 items-center">
      <ul class="flex gap-2 text-neutral-700 font-medium">
        {
          links.map(({ href, label, desktop, hasSub }) => {
            if (!desktop) return null;

            if (hasSub && label === 'Products') {
              return (
                <li class="relative">
                  <details id="products-dropdown" class="group peer">
                    <summary class="flex items-center justify-between gap-1 cursor-pointer px-3 py-2 text-sm font-medium text-neutral-700 rounded-lg transition hover:bg-neutral-50 hover:text-primary">
                      Products
                      <svg
                        class="w-4 h-4 transition-transform group-open:rotate-180"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M19 9l-7 7-7-7"
                        />
                      </svg>
                    </summary>

                    <div class="absolute right-0 mt-2 w-56 bg-white overflow-hidden shadow-xl rounded-2xl z-30">
                      <ul class="py-2">
                        {Object.entries(productsByCategory).map(
                          ([key, products]) => (
                            <li class="group relative">
                              <details class="group">
                                <summary class="flex justify-between items-center px-4 py-2 text-sm text-neutral-700 cursor-pointer hover:bg-neutral-50">
                                  {productCategoryToCategoryTitle[key]}
                                  <svg
                                    class="w-4 h-4 transition-transform group-open:rotate-90"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M9 5l7 7-7 7"
                                    />
                                  </svg>
                                </summary>
                                <ul class="pl-4 py-1 space-y-1 bg-white">
                                  {products.map(({ slug, name }) => (
                                    <li>
                                      <a
                                        href={'/product/' + slug}
                                        class="block px-4 py-1 text-sm text-neutral-700 hover:bg-neutral-100 rounded"
                                      >
                                        {name}
                                      </a>
                                    </li>
                                  ))}
                                </ul>
                              </details>
                            </li>
                          )
                        )}
                      </ul>
                    </div>
                  </details>
                </li>
              );
            }

            return (
              <li>
                {!href ? (
                  <button
                    class={`block px-3 py-2 text-sm transition-colors duration-200 text-neutral-700 hover:text-primary cursor-pointer contact-form-trigger`}
                  >
                    {label}
                  </button>
                ) : (
                  <a
                    href={href}
                    class={`block px-3 py-2 text-sm transition-colors duration-200 ${pathname === href ? 'text-primary font-semibold' : 'text-neutral-700 hover:text-primary'}`}
                  >
                    {label}
                  </a>
                )}
              </li>
            );
          })
        }
      </ul>
      <Image
        src={abgLogo}
        format="webp"
        widths={[48, 64]}
        sizes="(max-width: 768px) 48px, 64px"
        loading={'eager'}
        alt={'Aditya Birla Group Brand Logo'}
        layout="constrained"
        class={'w-10'}
      />
    </div>
  </nav>

  <!-- Mobile Overlay Menu -->
  <!-- Mobile Overlay Menu -->
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-white/75 backdrop-blur-3xl z-50 transform -translate-y-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <a class="w-32 absolute top-6 left-6" href="/" aria-label="Totalis Home">
      <Image
        src={totalisLogo}
        format="webp"
        loading={'eager'}
        widths={[160, 192]}
        sizes="(max-width: 768px) 160px, 198px"
        alt="Totalis Brand Logo"
        layout="constrained"
        class="w-40 opacity-90"
      />
    </a>

    <!-- Close Button -->
    <button
      id="menu-close"
      class="absolute top-6 right-6 text-neutral-700 hover:text-neutral-900 transition-colors duration-200"
      aria-label="Close menu"
    >
      <X class="size-6" stroke-width={1.25} />
    </button>

    <!-- Menu Content -->
    <div class="flex flex-col justify-center px-10 h-full pb-32 pt-8">
      <nav class="space-y-6">
        <a href="/" class="block text-2xl font-light">Home</a>
        <a href="/why" class="block text-2xl font-light">Why Totalis</a>

        {
          Object.entries(productsByCategory).map(([key, products]) => {
            return (
              <div>
                <span class="block text-2xl font-light mb-2">
                  {productCategoryToCategoryTitle[key]}
                </span>
                <ul class="pl-4 space-y-2">
                  {products.map(({ slug, name }) => (
                    <li>
                      <a
                        href={'/product/' + slug}
                        class="block text-xl font-light"
                      >
                        {name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })
        }

        <!-- Updated Brochure button - same behavior as desktop -->
        <button class="block text-2xl font-light text-left contact-form-trigger"
          >Brochure</button
        >
      </nav>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleBtn = document.getElementById('menu-toggle');
    const closeBtn = document.getElementById('menu-close');
    const overlay = document.getElementById('mobile-overlay');

    function openMenu() {
      overlay.classList.remove('-translate-y-full');
      overlay.classList.add('translate-y-0');
      document.body.classList.add('overflow-hidden');

      const menuItems = overlay.querySelectorAll('nav a, nav button');
      menuItems.forEach((item, index) => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(20px)';
        setTimeout(
          () => {
            item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
          },
          index * 100 + 200
        );
      });
    }

    function closeMenu() {
      overlay.classList.add('-translate-y-full');
      overlay.classList.remove('translate-y-0');
      document.body.classList.remove('overflow-hidden');
    }

    toggleBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    // Close menu when clicking on regular links (not buttons)
    const menuLinks = overlay.querySelectorAll('nav a');
    menuLinks.forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Handle brochure button in mobile menu
    const mobileBrochureBtn = overlay.querySelector(
      'nav button.contact-form-trigger'
    );
    if (mobileBrochureBtn) {
      mobileBrochureBtn.addEventListener('click', function (e) {
        // Trigger the same behavior as desktop brochure button
        const desktopBrochureBtn = document.querySelector(
          '.contact-form-trigger'
        );
        if (desktopBrochureBtn) {
          desktopBrochureBtn.click();
        }
        closeMenu();
      });
    }

    document.addEventListener('keydown', (e) => {
      if (
        e.key === 'Escape' &&
        !overlay.classList.contains('-translate-y-full')
      ) {
        closeMenu();
      }
    });

    // Handle click outside for desktop dropdown
    const productsDropdown = document.getElementById('products-dropdown');

    if (productsDropdown) {
      document.addEventListener('click', function (event) {
        // Check if the click is outside the dropdown
        if (!productsDropdown.contains(event.target)) {
          // Close the dropdown by setting open to false
          productsDropdown.open = false;
        }
      });

      // Also handle escape key for dropdown
      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && productsDropdown.open) {
          productsDropdown.open = false;
        }
      });
    }
  });
</script>

<style>
  @keyframes slideDown {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
