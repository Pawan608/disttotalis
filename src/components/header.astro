---
import { Image } from 'astro:assets';
import totalisLogo from '../assets/totalis-logo.png';
import { Hamburger, Menu } from '@lucide/astro';
---

<header class="z-20 w-full fixed lg:top-4 top-2">
  <nav
    class="h-20 mx-auto max-w-[calc(100dvw-2.75rem)] lg:max-w-7xl bg-[rgba(255,255,255,0.825)] drop-shadow-lg rounded-2xl backdrop-blur-sm px-4 sm:px-6 lg:px-8 flex justify-between items-center"
  >
    <div class="flex flex-row items-center">
      <Image
        src={totalisLogo}
        format="avif"
        alt={'Totalis Brand Logo'}
        layout="constrained"
        class={'w-24'}
      />
      <!-- <a href="/" class="text-lg font-semibold">Totalis.</a> -->
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden text-gray-700 focus:outline-none"
      aria-label="Toggle menu"
    >
      <Menu />
    </button>

    <!-- Links -->
    <ul
      id="mobile-menu"
      class="hidden md:flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-6 text-gray-600 font-medium absolute md:static bg-white w-full left-0 top-full md:w-auto md:bg-transparent px-4 md:px-0 shadow md:shadow-none z-50"
    >
      <li>
        <a
          href="/"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >Home</a
        >
      </li>
      <li>
        <a
          href="/about"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >About</a
        >
      </li>
      <li>
        <a
          href="/contact"
          class="block hover:text-primary hover:underline underline-offset-4 decoration-primary uppercase text-xs"
          >Contact</a
        >
      </li>
    </ul>
  </nav>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const toggleBtn = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggleBtn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    });
  </script>
</header>
