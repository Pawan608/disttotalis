---
import { ChevronLeft, CircleArrowLeft, CircleArrowRight } from '@lucide/astro';
import { Image } from 'astro:assets';
import demoImage from '../assets/building.jpeg';
import demoBrand from '../assets/hindalco.jpg';
import demoBuilding from '../assets/hotel-building.jpg';

// Property data array
const properties = [
  {
    id: 1,
    name: 'Supreme, Pune',
    area: '88544 Sqft.',
    image: demoImage,
  },
  {
    id: 2,
    name: 'Shalimar Mannat, Lucknow',
    area: '88544 Sqft.',
    image: demoBuilding,
  },
  {
    id: 3,
    name: 'Eldeco Luxa',
    area: '30000 Sqft.',
    image: demoImage,
  },
  {
    id: 4,
    name: 'Natura by One Oak, Lucknow',
    area: '75114 Sqft.',
    image: demoImage,
  },
  {
    id: 5,
    name: 'Supreme Elite, Mumbai',
    area: '95000 Sqft.',
    image: demoImage,
  },
  {
    id: 6,
    name: 'Shalimar Heights, Delhi',
    area: '72000 Sqft.',
    image: demoImage,
  },
];

// Brand logos for marquee
const brands = [demoBrand, demoBrand, demoBrand];
---

<section class="w-full">
  <!-- Properties Section -->
  <div class="bg-indigo-800 py-16 px-4">
    <div class="px-4 max-w-6xl mx-auto">
      <!-- Header with Navigation -->
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-white reveal">
          Shaping Skylines with excellence
        </h2>
        <div class="flex items-center gap-3 reveal" data-delay="200">
          <button
            id="embla-prev"
            class="text-white hover:text-indigo-300 transition-colors disabled:opacity-50"
            aria-label="Previous slide"
          >
            <CircleArrowLeft size={48} stroke-width={1.5} />
          </button>
          <button
            id="embla-next"
            class="text-white hover:text-indigo-300 transition-colors disabled:opacity-50"
            aria-label="Next slide"
          >
            <CircleArrowRight size={48} stroke-width={1.5} />
          </button>
        </div>
      </div>

      <!-- Embla Carousel Container -->
      <div class="embla" id="embla">
        <div class="embla__container">
          {
            properties.map((property) => (
              <div class="embla__slide">
                <div class="w-64 flex-shrink-0">
                  <div class="aspect-[8/9] overflow-hidden">
                    <div class="rounded-xl w-full bg-radial from-indigo-500 to-indigo-600 overflow-hidden h-full">
                      <Image
                        src={property.image}
                        alt={property.name}
                        loading={'lazy'}
                        decoding="async"
                        layout="full-width"
                        format="avif"
                        class="h-full object-cover hover:scale-105 transition-transform duration-400"
                      />
                    </div>
                  </div>
                  <div class="p-2">
                    <h3 class="text-md font-semibold text-white">
                      {property.name}
                    </h3>
                    <p class="text-gray-100 font-medium text-sm">
                      {property.area}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Trust Badge -->
      <div class="text-center mt-12">
        <div
          class="inline-flex items-center bg-white/10 backdrop-blur-sm rounded-full px-8 py-3"
        >
          <span class="text-white font-semibold text-lg"
            >Our Trusted Project</span
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Smooth Marquee Section -->
  <div class="bg-white py-8 overflow-hidden">
    <div class="marquee-container">
      <div class="marquee-content">
        {
          brands.map((brand, index) => (
            <Image
              src={brand}
              alt="Brand logo"
              class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity duration-300 flex-shrink-0 mx-8"
            />
          ))
        }
      </div>
      <div class="marquee-content" aria-hidden="true">
        {
          brands.map((brand, index) => (
            <Image
              src={brand}
              alt="Brand logo"
              class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity duration-300 flex-shrink-0 mx-8"
            />
          ))
        }
      </div>
    </div>
  </div>

  <!-- Testimonials Section -->
  <div class="bg-gradient-to-r from-green-400 to-green-600 py-16 px-4">
    <div class="max-w-7xl mx-auto text-center">
      <h3 class="text-lg font-semibold text-white/90 mb-4">Testimonials</h3>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">
        Real Voices, Genuine Experiences
      </h2>
      <p class="text-white/90 text-lg max-w-2xl mx-auto">
        Discover what our clients say about their transformative experiences
        working with us
      </p>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';

  document.addEventListener('DOMContentLoaded', () => {
    const emblaNode = document.getElementById('embla');
    const prevBtn = document.getElementById('embla-prev');
    const nextBtn = document.getElementById('embla-next');

    if (!emblaNode || !prevBtn || !nextBtn) return;

    // Embla options
    const options = {
      align: 'start' as const,
      slidesToScroll: 1,
      containScroll: 'trimSnaps' as const,
      dragFree: false,
      loop: false,
      skipSnaps: false,
      // Responsive breakpoints
      breakpoints: {
        '(min-width: 768px)': { slidesToScroll: 2 },
        '(min-width: 1024px)': { slidesToScroll: 3 },
      },
    };

    // Initialize Embla with autoplay plugin (optional)
    const embla = EmblaCarousel(emblaNode, options, [
      // Autoplay({ delay: 4000, stopOnInteraction: false }) // Uncomment for autoplay
    ]);

    // Button functionality
    const updateButtons = () => {
      const prevButton = prevBtn as HTMLButtonElement;
      const nextButton = nextBtn as HTMLButtonElement;

      prevButton.disabled = !embla.canScrollPrev();
      nextButton.disabled = !embla.canScrollNext();
    };

    prevBtn.addEventListener('click', () => {
      embla.scrollPrev();
    });

    nextBtn.addEventListener('click', () => {
      embla.scrollNext();
    });

    // Update buttons on slide change
    embla.on('select', updateButtons);
    embla.on('init', updateButtons);

    // Keyboard navigation
    emblaNode.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        embla.scrollPrev();
      } else if (e.key === 'ArrowRight') {
        embla.scrollNext();
      }
    });

    // Optional: Add dots/indicators
    const addDotButtons = () => {
      const parentNode = emblaNode.parentNode;
      if (!parentNode) return;

      const dotsContainer = document.createElement('div');
      dotsContainer.className = 'embla__dots flex justify-center mt-6 gap-2';

      embla.scrollSnapList().forEach((_, index) => {
        const dot = document.createElement('button');
        dot.className =
          'embla__dot w-2 h-2 rounded-full bg-white/30 hover:bg-white/60 transition-colors';
        dot.addEventListener('click', () => embla.scrollTo(index));
        dotsContainer.appendChild(dot);
      });

      parentNode.appendChild(dotsContainer);

      const updateDots = () => {
        const dots = dotsContainer.querySelectorAll('.embla__dot');
        dots.forEach((dot, index) => {
          dot.classList.toggle(
            'bg-white',
            index === embla.selectedScrollSnap()
          );
          dot.classList.toggle(
            'bg-white/30',
            index !== embla.selectedScrollSnap()
          );
        });
      };

      embla.on('select', updateDots);
      embla.on('init', updateDots);
    };

    // Uncomment to add dot indicators
    // addDotButtons();
  });
</script>

<style>
  /* Embla Carousel Styles */
  .embla {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    gap: 1.5rem;
  }

  .embla__slide {
    flex: 0 0 auto;
    min-width: 0;
  }

  /* Smooth Marquee CSS */
  .marquee-container {
    display: flex;
    overflow: hidden;
    user-select: none;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 5%,
      black 95%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 5%,
      black 95%,
      transparent
    );
  }

  .marquee-content {
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex-shrink: 0;
    min-width: 100%;
    animation: scroll-left 30s linear infinite;
  }

  .marquee-container:hover .marquee-content {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .marquee-content {
    will-change: transform;
  }

  @media (max-width: 768px) {
    .marquee-content {
      animation-duration: 20s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation-duration: 60s;
    }
  }
</style>
