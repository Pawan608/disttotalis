---
import { cx } from '../scripts/cx';

const {
  title,
  onClick,
  variant = 'default',
  reveal,
  link,
  animationDelay,
  color = 'green',
  classList,
  disabled = false,
  ariaLabel,
  ariaPressed,
  type = 'button',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 cursor-pointer py-2 px-4 rounded-xl focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed';

const primary =
  'bg-primary/90 backdrop-blur-sm backdrop-brightness-130 border border-primary text-white focus:ring-primary outline-transparent hover:outline-primary outline-offset-8 hover:outline-offset-4 outline-2 hover:scale-95';
const primaryBlue =
  'bg-secondary border border-secondary/70 hover:outline-secondary focus:ring-secondary';

const secondary =
  'bg-primary/5 border-2 border-primary text-primary-glass-text backdrop-blur-sm backdrop-brightness-110 focus:ring-primary outline-transparent outline-offset-8 hover:outline-primary hover:outline-offset-4 outline-2 hover:scale-95';
const secondaryBlue =
  'bg-transparent border-secondary text-secondary hover:outline-secondary focus:ring-secondary';

const outline =
  'border-2 border-primary text-primary focus:ring-primary outline-transparent outline-offset-8 hover:outline-primary hover:outline-offset-4 outline-2 hover:scale-95';

const fallback =
  'bg-gray-200 hover:bg-gray-300 text-gray-800 focus:ring-gray-400';

const variantClass = cx(
  variant === 'primary' && [primary, color === 'blue' && primaryBlue],
  variant === 'secondary' && [secondary, color === 'blue' && secondaryBlue],
  variant === 'outline' && outline,
  variant === 'default' && fallback
);

const className = cx(base, variantClass, reveal && 'reveal', classList);
---

{
  link ? (
    <a href={link} class={className} data-delay={animationDelay}>
      <slot name="startIcon" />
      <slot />
      <slot name="endIcon" />
    </a>
  ) : (
    <button
      onclick={onClick}
      class={className}
      data-delay={animationDelay}
      type={type}
      disabled={disabled}
      aria-label={ariaLabel || title}
      aria-pressed={ariaPressed}
      role="button"
      tabindex={disabled ? -1 : 0}
    >
      <slot />
    </button>
  )
}
